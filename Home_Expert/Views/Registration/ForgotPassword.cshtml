@using Home_Expert.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> _sharedResources

@{
    Layout = null;
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isArabic = culture.StartsWith("ar");
    var step = TempData["ForgotStep"] as string ?? "1";
    var email = TempData["ForgotEmail"] as string ?? "";
    var error = TempData["ForgotError"] as string;
}

<!DOCTYPE html>
<html lang="@culture" dir="@(isArabic ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@_sharedResources[SharedResourcesKeys.Project_Title]</title>
    <link rel="icon" href="~/img/logo.png" type="image/x-icon">
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/accountstyles.css" rel="stylesheet" />
</head>
<body>
    <div class="main-wrapper">

        <!-- Hero Section -->
        <div class="hero-section">
            <img src="~/img/logimg.png" alt="Forgot Password" class="hero-image">
            <div class="hero-overlay"></div>
            <div class="hero-content">
                <div class="d-flex align-items-center justify-content-center gap-3">
                    <img src="~/img/logo.png" alt="Logo" style="width: 60px; height: 60px; object-fit: contain;">
                    <h1 class="hero-logo mb-0">
                        @_sharedResources[SharedResourcesKeys.Project_Title]<span class="logo-dot"></span>
                    </h1>
                </div>
                <p style="color: rgba(255,255,255,0.85); font-size: 1.1rem; margin-top: 16px; text-align: center;">
                    @(isArabic ? "شريكك الموثوق لجميع خدمات المنزل" : "Your trusted partner for all home services")
                </p>
            </div>
        </div>

        <!-- Content Section -->
        <div class="form-section">

            <!-- Language Toggle -->
            <div class="language-toggle">
                <form id="languageForm" asp-controller="Language" asp-action="SetLanguage" method="post">
                    <input type="hidden" name="culture" id="cultureInput" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <button type="button" onclick="toggleLanguage()" class="btn-language">
                        @if (isArabic)
                        {
                            <div class="btn-lang-en"><span class="material-symbols-outlined">language</span>English</div>
                        }
                        else
                        {
                            <div class="btn-lang-ar"><span class="material-symbols-outlined">language</span>العربية</div>
                        }
                    </button>
                </form>
            </div>

            <div class="form-container">

                <!-- Step Indicator -->
                <div class="d-flex justify-content-center align-items-center gap-2 mb-4">
                    @for (int i = 1; i <= 3; i++)
                    {
                        var isActive = step == i.ToString();
                        var isDone = int.Parse(step) > i;
                        <div class="d-flex align-items-center">
                            <div style="width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:600; font-size:0.9rem;
                                        background: @(isActive ? "#667eea" : isDone ? "#10b981" : "#e5e7eb");
                                        color: @(isActive || isDone ? "white" : "#9ca3af");">
                                @if (isDone)
                                {
                                    <span class="material-symbols-outlined" style="font-size:16px;">check</span>
                                }
                                else
                                {
                                    @i
                                }
                            </div>
                            @if (i < 3)
                            {
                                <div style="width:40px; height:2px; background: @(isDone ? "#10b981" : "#e5e7eb");"></div>
                            }
                        </div>
                    }
                </div>

                <!-- Error Message -->
                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger text-center mb-3">@error</div>
                }

                <!-- ===== STEP 1: إدخال الإيميل ===== -->
                @if (step == "1")
                {
                    <div class="text-center mb-4">
                        <span class="material-symbols-outlined" style="font-size: 60px; color: #667eea;">lock_reset</span>
                        <h2 class="form-title mt-2">@(isArabic ? "نسيت كلمة المرور؟" : "Forgot Password?")</h2>
                        <p class="text-muted">@(isArabic ? "أدخل بريدك الإلكتروني وسنرسل لك رمز التحقق" : "Enter your email and we'll send you a verification code")</p>
                    </div>

                    <form asp-controller="Registration" asp-action="ForgotPasswordSendOtp" method="post">
                        @Html.AntiForgeryToken()
                        <div class="form-group mb-3">
                            <label class="form-label">@(isArabic ? "البريد الإلكتروني" : "Email Address")</label>
                            <input type="email" name="email" class="form-control" required
                                   placeholder="@(isArabic ? "أدخل بريدك الإلكتروني" : "Enter your email")" />
                        </div>
                        <button type="submit" class="btn-submit w-100 mt-3" style="display:flex; justify-content:center;">
                            @(isArabic ? "إرسال رمز التحقق" : "Send Verification Code")
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <a href="/Registration/Login" class="text-muted" style="font-size:0.9rem;">
                            @(isArabic ? "العودة لتسجيل الدخول" : "Back to Login")
                        </a>
                    </div>
                }

                <!-- ===== STEP 2: إدخال OTP ===== -->
                @if (step == "2")
                {
                    <div class="text-center mb-4">
                        <span class="material-symbols-outlined" style="font-size: 60px; color: #667eea;">mark_email_read</span>
                        <h2 class="form-title mt-2">@(isArabic ? "أدخل رمز التحقق" : "Enter Verification Code")</h2>
                        <p class="text-muted">
                            @(isArabic ? "تم إرسال الرمز إلى" : "Code sent to")
                            <strong>@email</strong>
                        </p>
                    </div>

                    <form asp-controller="Registration" asp-action="ForgotPasswordVerifyOtp" method="post">
                        @Html.AntiForgeryToken()
                        <div class="form-group mb-3">
                            <label class="form-label">@(isArabic ? "رمز التحقق" : "Verification Code")</label>
                            <input type="text" name="otpCode" class="form-control text-center"
                                   maxlength="6" required style="font-size:1.5rem; letter-spacing:8px;"
                                   placeholder="------" />
                        </div>
                        <button type="submit" class="btn-submit w-100 mt-3" style="display:flex; justify-content:center;">
                            @(isArabic ? "تحقق من الرمز" : "Verify Code")
                        </button>
                    </form>

                    <div class="text-center mt-3">
                        <form asp-controller="Registration" asp-action="ForgotPasswordSendOtp" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="email" value="@email" />
                            <button type="submit" class="btn btn-link text-muted p-0" style="font-size:0.9rem;">
                                @(isArabic ? "إعادة إرسال الرمز" : "Resend Code")
                            </button>
                        </form>
                    </div>
                }

                <!-- ===== STEP 3: كلمة المرور الجديدة ===== -->
                @if (step == "3")
                {
                    <div class="text-center mb-4">
                        <span class="material-symbols-outlined" style="font-size: 60px; color: #10b981;">lock_open</span>
                        <h2 class="form-title mt-2">@(isArabic ? "كلمة المرور الجديدة" : "New Password")</h2>
                        <p class="text-muted">@(isArabic ? "أدخل كلمة المرور الجديدة" : "Enter your new password")</p>
                    </div>

                    <form asp-controller="Registration" asp-action="ForgotPasswordReset" method="post">
                        @Html.AntiForgeryToken()
                        <div class="form-group mb-3">
                            <label class="form-label">@(isArabic ? "كلمة المرور الجديدة" : "New Password")</label>
                            <input type="password" name="newPassword" class="form-control" required
                                   placeholder="@(isArabic ? "أدخل كلمة المرور الجديدة" : "Enter new password")" />
                        </div>
                        <div class="form-group mb-3">
                            <label class="form-label">@(isArabic ? "تأكيد كلمة المرور" : "Confirm Password")</label>
                            <input type="password" name="confirmPassword" class="form-control" required
                                   placeholder="@(isArabic ? "أعد إدخال كلمة المرور" : "Re-enter password")" />
                        </div>
                        <button type="submit" class="btn-submit w-100 mt-3" style="display:flex; justify-content:center;">
                            @(isArabic ? "تغيير كلمة المرور" : "Reset Password")
                        </button>
                    </form>
                }

            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleLanguage() {
            var currentCulture = '@culture';
            var newCulture = currentCulture.startsWith('ar') ? 'en-US' : 'ar-JO';
            document.getElementById('cultureInput').value = newCulture;
            document.getElementById('languageForm').submit();
        }
    </script>
</body>
</html>