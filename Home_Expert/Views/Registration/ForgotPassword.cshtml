@using Home_Expert.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> _sharedResources

@{
    Layout = null;
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isArabic = culture.StartsWith("ar");
    var step = TempData["ForgotStep"] as string ?? "1";
    var email = TempData["ForgotEmail"] as string ?? "";
    var error = TempData["ForgotError"] as string;
}

<!DOCTYPE html>
<html lang="@culture" dir="@(isArabic ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@_sharedResources[SharedResourcesKeys.Project_Title]</title>
    <link rel="icon" href="~/img/logo.png" type="image/x-icon">
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/accountstyles.css" rel="stylesheet" />
</head>
<body>
<div class="main-wrapper">

    <!-- Hero Section -->
    <div class="hero-section">
        <img src="~/img/logimg.png" alt="Forgot Password" class="hero-image">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="d-flex align-items-center gap-3">
                <img src="~/img/logo.png" alt="Logo" style="width: 60px; height: 60px; object-fit: contain;">
                <h1 class="hero-logo mb-0">
                    @_sharedResources[SharedResourcesKeys.Project_Title]<span class="logo-dot"></span>
                </h1>
            </div>

            <div class="hero-main">
                <h2 class="hero-title">
                    @(isArabic ? "استعادة كلمة المرور" : "Password Recovery")
                </h2>
                <p class="hero-description">
                    @(isArabic
                        ? "لا تقلق! سنساعدك على استعادة حسابك بخطوات بسيطة وآمنة."
                        : "Don't worry! We'll help you recover your account in simple and secure steps.")
                </p>

                <!-- Step Indicators in Hero -->
                <div class="d-flex flex-column gap-3 mt-4">
                    <div class="d-flex align-items-center gap-3">
                        <div style="width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700;
                                    background: @(step == "1" ? "var(--accent)" : int.Parse(step) > 1 ? "rgba(255,255,255,0.9)" : "rgba(255,255,255,0.2)");
                                    color: @(int.Parse(step) > 1 ? "var(--primary)" : "white");
                                    border: 2px solid @(step == "1" ? "var(--accent)" : "rgba(255,255,255,0.4)");">
                            @if (int.Parse(step) > 1)
                            {
                                <span class="material-symbols-outlined" style="font-size:18px;">check</span>
                            }
                            else
                            {
                                <span>1</span>
                            }
                        </div>
                        <span style="color: @(step == "1" ? "white" : "rgba(255,255,255,0.6)"); font-weight: @(step == "1" ? "600" : "400");">
                            @(isArabic ? "أدخل بريدك الإلكتروني" : "Enter your email")
                        </span>
                    </div>
                    <div style="width:2px; height:20px; background:rgba(255,255,255,0.2); margin-inline-start:17px;"></div>
                    <div class="d-flex align-items-center gap-3">
                        <div style="width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700;
                                    background: @(step == "2" ? "var(--accent)" : int.Parse(step) > 2 ? "rgba(255,255,255,0.9)" : "rgba(255,255,255,0.2)");
                                    color: @(int.Parse(step) > 2 ? "var(--primary)" : "white");
                                    border: 2px solid @(step == "2" ? "var(--accent)" : "rgba(255,255,255,0.4)");">
                            @if (int.Parse(step) > 2)
                            {
                                <span class="material-symbols-outlined" style="font-size:18px;">check</span>
                            }
                            else
                            {
                                <span>2</span>
                            }
                        </div>
                        <span style="color: @(step == "2" ? "white" : "rgba(255,255,255,0.6)"); font-weight: @(step == "2" ? "600" : "400");">
                            @(isArabic ? "تحقق من رمز OTP" : "Verify OTP code")
                        </span>
                    </div>
                    <div style="width:2px; height:20px; background:rgba(255,255,255,0.2); margin-inline-start:17px;"></div>
                    <div class="d-flex align-items-center gap-3">
                        <div style="width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700;
                                    background: @(step == "3" ? "var(--accent)" : "rgba(255,255,255,0.2)");
                                    color: white;
                                    border: 2px solid @(step == "3" ? "var(--accent)" : "rgba(255,255,255,0.4)");">
                            <span>3</span>
                        </div>
                        <span style="color: @(step == "3" ? "white" : "rgba(255,255,255,0.6)"); font-weight: @(step == "3" ? "600" : "400");">
                            @(isArabic ? "كلمة المرور الجديدة" : "New password")
                        </span>
                    </div>
                </div>
            </div>

            <div class="hero-footer">
                <span>@_sharedResources[SharedResourcesKeys.Footer_Copyright]</span>
            </div>
        </div>
    </div>

    <!-- Form Section -->
    <div class="form-section">

        <!-- Language Toggle -->
        <div class="language-toggle">
            <form id="languageForm" asp-controller="Language" asp-action="SetLanguage" method="post">
                <input type="hidden" name="culture" id="cultureInput" />
                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                <button type="button" onclick="toggleLanguage()" class="btn-language">
                    @if (isArabic)
                    {
                        <div class="btn-lang-en"><span class="material-symbols-outlined">language</span>English</div>
                    }
                    else
                    {
                        <div class="btn-lang-ar"><span class="material-symbols-outlined">language</span>العربية</div>
                    }
                </button>
            </form>
        </div>

        <div class="form-container">

            <!-- Progress Steps -->
            <div class="progress-steps">
                <div class="step-item @(step == "1" ? "active" : int.Parse(step) > 1 ? "completed" : "")">
                    <span class="step-number">
                        @if (int.Parse(step) > 1)
                        {
                            <span class="material-symbols-outlined" style="font-size:1rem;">check</span>
                        }
                        else
                        {
                            <span>1</span>
                        }
                    </span>
                    <span class="step-label">@(isArabic ? "البريد" : "Email")</span>
                </div>
                <div class="step-divider @(int.Parse(step) > 1 ? "completed" : "")"></div>
                <div class="step-item @(step == "2" ? "active" : int.Parse(step) > 2 ? "completed" : "")">
                    <span class="step-number">
                        @if (int.Parse(step) > 2)
                        {
                            <span class="material-symbols-outlined" style="font-size:1rem;">check</span>
                        }
                        else
                        {
                            <span>2</span>
                        }
                    </span>
                    <span class="step-label">@(isArabic ? "التحقق" : "Verify")</span>
                </div>
                <div class="step-divider @(int.Parse(step) > 2 ? "completed" : "")"></div>
                <div class="step-item @(step == "3" ? "active" : "")">
                    <span class="step-number">3</span>
                    <span class="step-label">@(isArabic ? "كلمة المرور" : "Password")</span>
                </div>
            </div>

            <!-- Error -->
            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger mb-4">
                    <span class="material-symbols-outlined me-2">error</span>
                    @error
                </div>
            }

            <!-- ===== STEP 1 ===== -->
            @if (step == "1")
            {
                <div class="form-header">
                    <h2 class="form-title">@(isArabic ? "نسيت كلمة المرور؟" : "Forgot Password?")</h2>
                    <p class="form-subtitle">@(isArabic ? "أدخل بريدك الإلكتروني وسنرسل لك رمز التحقق" : "Enter your email and we'll send you a verification code")</p>
                </div>

                <form asp-controller="Registration" asp-action="ForgotPasswordSendOtp" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label class="form-label">@(isArabic ? "البريد الإلكتروني" : "Email Address")</label>
                        <div class="input-group-custom">
                            <span class="material-symbols-outlined input-icon">mail</span>
                            <input type="email" name="email" class="form-control-custom" required
                                   placeholder="@(isArabic ? "أدخل بريدك الإلكتروني" : "Enter your email")" />
                        </div>
                    </div>
                    <button type="submit" class="btn-submit">
                        @(isArabic ? "إرسال رمز التحقق" : "Send Verification Code")
                        <span class="material-symbols-outlined btn-arrow">arrow_forward</span>
                    </button>
                </form>

                <p class="signin-link mt-4">
                    <a href="/Registration/Login" class="link-accent">
                        @(isArabic ? "العودة لتسجيل الدخول" : "Back to Login")
                    </a>
                </p>
            }

            <!-- ===== STEP 2 ===== -->
                @if (step == "2")
                {
                    <div class="form-header">
                        <h2 class="form-title">@(isArabic ? "أدخل رمز التحقق" : "Enter Verification Code")</h2>
                        <p class="form-subtitle">
                            @(isArabic ? "تم إرسال الرمز إلى" : "Code sent to")
                            <strong>@email</strong>
                        </p>
                    </div>

                    <form asp-controller="Registration" asp-action="ForgotPasswordVerifyOtp" method="post" id="otpForm">
                        @Html.AntiForgeryToken()

                        <div class="otp-icon-container">
                            <div class="otp-icon">
                                <span class="material-symbols-outlined">mark_email_read</span>
                            </div>
                        </div>

                        <div class="otp-inputs mb-3">
                            <input type="text" maxlength="1" class="otp-input" id="otp1" pattern="[0-9]" inputmode="numeric" required>
                            <input type="text" maxlength="1" class="otp-input" id="otp2" pattern="[0-9]" inputmode="numeric" required>
                            <input type="text" maxlength="1" class="otp-input" id="otp3" pattern="[0-9]" inputmode="numeric" required>
                            <input type="text" maxlength="1" class="otp-input" id="otp4" pattern="[0-9]" inputmode="numeric" required>
                            <input type="text" maxlength="1" class="otp-input" id="otp5" pattern="[0-9]" inputmode="numeric" required>
                            <input type="text" maxlength="1" class="otp-input" id="otp6" pattern="[0-9]" inputmode="numeric" required>
                        </div>

                        <!-- Hidden OTP combined -->
                        <input type="hidden" name="otpCode" id="otpCodeHidden" />

                        <div class="otp-timer">
                            <p class="timer-text">
                                @(isArabic ? "ينتهي الرمز خلال" : "Code expires in")
                                <span id="timer" class="timer-countdown">05:00</span>
                            </p>
                        </div>

                        <button type="submit" class="btn-submit" id="verifyBtn">
                            @(isArabic ? "تحقق من الرمز" : "Verify Code")
                            <span class="material-symbols-outlined btn-arrow">arrow_forward</span>
                        </button>
                    </form>

                    <div class="resend-container">
                        <form asp-controller="Registration" asp-action="ForgotPasswordSendOtp" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="email" value="@email" />
                            <button type="submit" class="btn-resend" id="resendBtn" disabled>
                                @(isArabic ? "إعادة إرسال الرمز" : "Resend Code")
                            </button>
                        </form>
                    </div>
                }

            <!-- ===== STEP 3 ===== -->
            @if (step == "3")
            {
                <div class="form-header">
                    <h2 class="form-title">@(isArabic ? "كلمة المرور الجديدة" : "New Password")</h2>
                    <p class="form-subtitle">@(isArabic ? "أدخل كلمة المرور الجديدة الخاصة بك" : "Enter your new password below")</p>
                </div>

                <form asp-controller="Registration" asp-action="ForgotPasswordReset" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label class="form-label">@(isArabic ? "كلمة المرور الجديدة" : "New Password")</label>
                        <div class="input-group-custom">
                            <span class="material-symbols-outlined input-icon">lock</span>
                            <input type="password" name="newPassword" id="newPassword" class="form-control-custom" required
                                   placeholder="••••••••" minlength="8" />
                            <button type="button" class="password-toggle" onclick="togglePassword('newPassword','iconNew')">
                                <span class="material-symbols-outlined" id="iconNew">visibility</span>
                            </button>
                        </div>
                        <div class="password-strength" id="passwordStrength">
                            <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                            <span class="strength-text" id="strengthText"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">@(isArabic ? "تأكيد كلمة المرور" : "Confirm Password")</label>
                        <div class="input-group-custom">
                            <span class="material-symbols-outlined input-icon">lock_open</span>
                            <input type="password" name="confirmPassword" id="confirmPassword" class="form-control-custom" required
                                   placeholder="••••••••" />
                            <button type="button" class="password-toggle" onclick="togglePassword('confirmPassword','iconConfirm')">
                                <span class="material-symbols-outlined" id="iconConfirm">visibility</span>
                            </button>
                        </div>
                        <div id="matchMsg" style="font-size:12px; margin-top:5px;"></div>
                    </div>

                    <button type="submit" class="btn-submit">
                        @(isArabic ? "تغيير كلمة المرور" : "Reset Password")
                        <span class="material-symbols-outlined btn-arrow">arrow_forward</span>
                    </button>
                </form>
            }

        </div>
    </div>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const IS_ARABIC = '@isArabic' === 'True';
        const CURRENT_STEP = '@step';

        function toggleLanguage() {
            var currentCulture = '@culture';
            var newCulture = currentCulture.startsWith('ar') ? 'en-US' : 'ar-JO';
            document.getElementById('cultureInput').value = newCulture;
            document.getElementById('languageForm').submit();
        }

        function togglePassword(fieldId, iconId) {
            const input = document.getElementById(fieldId);
            const icon  = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility_off';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility';
            }
        }

        function hasSpecialChar(str) {
            return /[!@@#$%^&*()_+\-={}|:;<>?,./]/.test(str);
        }

        document.addEventListener('DOMContentLoaded', function () {

            // ===== OTP Step =====
        if (CURRENT_STEP === '2') {
            const inputs    = document.querySelectorAll('.otp-input');
            const timerEl   = document.getElementById('timer');
            const resendBtn = document.getElementById('resendBtn');
            const otpForm   = document.getElementById('otpForm');
            const verifyBtn = document.getElementById('verifyBtn');

            // OTP Input Handlers
            inputs.forEach((input, index) => {
                input.addEventListener('input', function (e) {
                    // Remove non-digit characters
                    const value = e.target.value.replace(/[^0-9]/g, '');
                    e.target.value = value;

                    // Move to next input
                    if (value && index < inputs.length - 1) {
                        inputs[index + 1].focus();
                    }
                });

                input.addEventListener('keydown', function (e) {
                    // Move to previous on backspace
                    if (e.key === 'Backspace' && !e.target.value && index > 0) {
                        inputs[index - 1].focus();
                    }
                });

                // Prevent paste of non-digits
                input.addEventListener('paste', function (e) {
                    e.preventDefault();
                    const pastedData = e.clipboardData.getData('text');
                    const digits = pastedData.replace(/[^0-9]/g, '').split('');

                    digits.forEach((digit, i) => {
                        if (index + i < inputs.length) {
                            inputs[index + i].value = digit;
                        }
                    });

                    // Focus last filled input
                    const lastIndex = Math.min(index + digits.length, inputs.length - 1);
                    inputs[lastIndex].focus();
                });
            });

            // Form Submit Handler
            otpForm?.addEventListener('submit', function (e) {
                e.preventDefault();

                // Combine OTP
                const otp = Array.from(inputs).map(i => i.value.trim()).join('');

                console.log('OTP Collected:', otp); // للتأكد

                // Validate
                if (otp.length !== 6 || !/^\d{6}$/.test(otp)) {
                    alert(IS_ARABIC ? 'يرجى إدخال رمز صحيح مكون من 6 أرقام' : 'Please enter a valid 6-digit code');
                    return false;
                }

                // Set hidden input
                document.getElementById('otpCodeHidden').value = otp;

                // Disable button and show loading
                verifyBtn.disabled = true;
                const originalText = verifyBtn.innerHTML;
                verifyBtn.innerHTML = '<span class="spinner-border spinner-border-sm ' + (IS_ARABIC ? 'ms-2' : 'me-2') + '"></span> ' + (IS_ARABIC ? 'جاري التحقق...' : 'Verifying...');

                // Submit form
                this.submit();
            });

            // Timer
            let timeLeft = 300;
            const countdown = setInterval(() => {
                timeLeft--;
                const m = Math.floor(timeLeft / 60);
                const s = timeLeft % 60;
                timerEl.textContent = m.toString().padStart(2,'0') + ':' + s.toString().padStart(2,'0');

                if (timeLeft <= 0) {
                    clearInterval(countdown);
                    if (resendBtn) {
                        resendBtn.disabled = false;
                        resendBtn.classList.add('active');
                    }
                }
            }, 1000);

            // Focus first input
            if (inputs[0]) inputs[0].focus();
        }
            // ===== Password Step =====
            if (CURRENT_STEP === '3') {
                document.getElementById('newPassword')?.addEventListener('input', function (e) {
                    const password = e.target.value;
                    const strengthContainer = document.getElementById('passwordStrength');
                    const strengthText = document.getElementById('strengthText');
                    if (!password) {
                        strengthContainer.classList.remove('visible','strength-weak','strength-medium','strength-strong');
                        return;
                    }
                    let strength = 0;
                    if (password.length >= 8)     strength++;
                    if (/[a-z]/.test(password))   strength++;
                    if (/[A-Z]/.test(password))   strength++;
                    if (/\d/.test(password))      strength++;
                    if (hasSpecialChar(password)) strength++;
                    strengthContainer.className = 'password-strength visible';
                    if (strength <= 2)      { strengthContainer.classList.add('strength-weak');   strengthText.textContent = IS_ARABIC ? 'ضعيفة'   : 'Weak'; }
                    else if (strength <= 4) { strengthContainer.classList.add('strength-medium'); strengthText.textContent = IS_ARABIC ? 'متوسطة' : 'Medium'; }
                    else                    { strengthContainer.classList.add('strength-strong'); strengthText.textContent = IS_ARABIC ? 'قوية'    : 'Strong'; }
                });

                document.getElementById('confirmPassword')?.addEventListener('input', function () {
                    const pass    = document.getElementById('newPassword').value;
                    const confirm = this.value;
                    const msg     = document.getElementById('matchMsg');
                    if (!confirm) { msg.textContent = ''; return; }
                    if (pass === confirm) {
                        msg.style.color = '#198754';
                        msg.textContent = IS_ARABIC ? '✓ كلمات المرور متطابقة' : '✓ Passwords match';
                    } else {
                        msg.style.color = '#dc3545';
                        msg.textContent = IS_ARABIC ? '✗ كلمات المرور غير متطابقة' : '✗ Passwords do not match';
                    }
                });
            }
        });
    </script>
</body>
</html>