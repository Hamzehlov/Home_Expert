@using Home_Expert.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> _sharedResources
@model Home_Expert.Models.Vendor
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isArabic = culture.StartsWith("ar");
    var dir = isArabic ? "rtl" : "ltr";

    var companyName = isArabic ? Model.CompanyNameAr : Model.CompanyNameEn;
    var companyNameAlt = isArabic ? Model.CompanyNameEn : Model.CompanyNameAr;
    var descriptionTxt = isArabic ? Model.DescriptionAr : Model.DescriptionEn;
    var addressTxt = isArabic ? Model.ShowroomAddressAr : Model.ShowroomAddressEn;
    var serviceType = isArabic ? Model.ServiceType?.DescCodeAr ?? "-" : Model.ServiceType?.DescCodeEn ?? "-";
    var rejectionReason = isArabic
        ? (Model.RejectionReasonAr ?? Model.RejectionReasonEn)
        : (Model.RejectionReasonEn ?? Model.RejectionReasonAr);

    // User Info
    var userFirstName = isArabic 
        ? (Model.User?.FirstNameAr ?? Model.User?.FirstNameEn ?? "")
        : (Model.User?.FirstNameEn ?? Model.User?.FirstNameAr ?? "");
  
    var userInitial = userFirstName.Length > 0 ? userFirstName[0].ToString().ToUpper() : "C";
    var userEmail = Model.User?.Email ?? "—";
    var userPhone = Model.User?.Phone ?? Model.PhoneNumber ?? "—";

    string statusLabel, statusClass, statusIcon;
    switch (Model.Verified)
    {
        case 1:
            statusLabel = _sharedResources[SharedResourcesKeys.Status_Approved].Value;
            statusClass = "badge-approved";
            statusIcon = "verified";
            break;
        case 2:
            statusLabel = _sharedResources[SharedResourcesKeys.Status_Rejected].Value;
            statusClass = "badge-rejected";
            statusIcon = "cancel";
            break;
        default:
            statusLabel = _sharedResources[SharedResourcesKeys.Status_Pending].Value;
            statusClass = "badge-pending";
            statusIcon = "pending_actions";
            break;
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/details.css" />
}

<div class="page-wrapper" dir="@dir">

    <!-- Page Header -->
    <div class="page-header">
        <div class="page-header-text">
            <div class="breadcrumb">
                <a href="@Url.Action("Index", "Home")">
                    <span class="material-symbols-outlined" style="font-size:1rem;vertical-align:middle;">home</span>
                    @_sharedResources[SharedResourcesKeys.Dashboard]
                </a>
                <span class="material-symbols-outlined sep">@(isArabic ? "chevron_left" : "chevron_right")</span>
                <a href="@Url.Action("Index", "VendorApplications")">@_sharedResources[SharedResourcesKeys.PendingVendors_Title]</a>
                <span class="material-symbols-outlined sep">@(isArabic ? "chevron_left" : "chevron_right")</span>
                <span>@companyName</span>
            </div>
            <h1>@companyName</h1>
            <p>@companyNameAlt</p>
        </div>
        <div class="header-actions">
            <a href="@Url.Action("Index", "VendorApplications")" class="btn btn-outline">
                <span class="material-symbols-outlined">@(isArabic ? "arrow_forward" : "arrow_back")</span>
                @_sharedResources[SharedResourcesKeys.Back]
            </a>
        </div>
    </div>

    <!-- Hero Banner -->
    <div class="detail-hero">
        <div class="detail-hero-logo">
            @if (Model.Logo != null)
            {
                <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.Logo)" alt="@companyName" />
            }
            else
            {
                <span class="material-symbols-outlined">storefront</span>
            }
        </div>
        <div class="detail-hero-text">
            <h2>@companyName</h2>
            <p>@serviceType &nbsp;·&nbsp; #@Model.Id</p>
        </div>
        <div class="detail-hero-stats">
            @if (Model.RatingAvg.HasValue)
            {
                <div class="dh-stat">
                    <div class="dh-stat-val" style="color:#fbbf24;">★ @Model.RatingAvg.Value.ToString("0.0")</div>
                    <div class="dh-stat-label">@_sharedResources[SharedResourcesKeys.Rating]</div>
                </div>
                <div class="dh-divider"></div>
            }
            @if (Model.CompletedOrders.HasValue)
            {
                <div class="dh-stat">
                    <div class="dh-stat-val">@Model.CompletedOrders</div>
                    <div class="dh-stat-label">@_sharedResources[SharedResourcesKeys.Srv_TotalOrders]</div>
                </div>
                <div class="dh-divider"></div>
            }
            @if (Model.YearsExperience.HasValue)
            {
                <div class="dh-stat">
                    <div class="dh-stat-val">@Model.YearsExperience</div>
                    <div class="dh-stat-label">@_sharedResources[SharedResourcesKeys.Vendors_Experience]</div>
                </div>
                <div class="dh-divider"></div>
            }
            <div class="dh-stat">
                <span class="status-badge @statusClass">
                    <span class="material-symbols-outlined" style="font-size:.9rem;">@statusIcon</span>
                    @statusLabel
                </span>
            </div>
        </div>
    </div>

    <!-- Rejection Alert -->
    @if (Model.Verified == 2 && !string.IsNullOrWhiteSpace(rejectionReason))
    {
        <div class="alert alert-danger">
            <span class="material-symbols-outlined">error</span>
            <div>
                <strong>@_sharedResources[SharedResourcesKeys.Rejection_Title]:</strong>
                @rejectionReason
            </div>
        </div>
    }

    <!-- Main Grid -->
    <div class="detail-grid">

        <!-- Main Column -->
        <div class="detail-col-main">

            <!-- User Information Card -->
            <div class="detail-card">
                <div class="detail-card-header">
                    <div class="header-icon"><span class="material-symbols-outlined">person</span></div>
                    <h3>@(isArabic ? "معلومات صاحب الطلب" : "Applicant Information")</h3>
                </div>
                <div class="detail-card-body">
                    <div class="user-info-card">
                        <div class="user-info-header">
                            <div class="user-avatar">@userInitial</div>
                            <div class="user-info-text">
                                <h4>@userFirstName</h4>
                                <p>@(isArabic ? "صاحب الطلب" : "Account Owner")</p>
                            </div>
                        </div>
                        <div class="user-contact-grid">
                            <div class="contact-item">
                                <div class="contact-icon">
                                    <span class="material-symbols-outlined">mail</span>
                                </div>
                                <div class="contact-info">
                                    <div class="contact-label">@(isArabic ? "البريد الإلكتروني" : "Email")</div>
                                    <div class="contact-value">@userEmail</div>
                                </div>
                            </div>
                            <div class="contact-item">
                                <div class="contact-icon">
                                    <span class="material-symbols-outlined">phone</span>
                                </div>
                                <div class="contact-info">
                                    <div class="contact-label">@(isArabic ? "رقم الهاتف" : "Phone")</div>
                                    <div class="contact-value" style="direction:ltr;text-align:start;">@userPhone</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Company Details Card -->
            <div class="detail-card">
                <div class="detail-card-header">
                    <div class="header-icon"><span class="material-symbols-outlined">business</span></div>
                    <h3>@_sharedResources[SharedResourcesKeys.Vendors_CompanyName]</h3>
                </div>
                <div class="detail-card-body">
                    <div class="info-grid">
                        <div>
                            <div class="info-label">
                                <span class="material-symbols-outlined" style="font-size:.9rem;">translate</span>
                                @(isArabic ? "الاسم بالعربي" : "Arabic Name")
                            </div>
                            <div class="info-value">@Model.CompanyNameAr</div>
                        </div>
                        <div>
                            <div class="info-label">
                                <span class="material-symbols-outlined" style="font-size:.9rem;">language</span>
                                @(isArabic ? "الاسم بالإنجليزي" : "English Name")
                            </div>
                            <div class="info-value">@Model.CompanyNameEn</div>
                        </div>
                        <div>
                            <div class="info-label">
                                <span class="material-symbols-outlined" style="font-size:.9rem;">category</span>
                                @_sharedResources[SharedResourcesKeys.Vendors_ServiceType]
                            </div>
                            <div class="info-value">@serviceType</div>
                        </div>
                        <div>
                            <div class="info-label">
                                <span class="material-symbols-outlined" style="font-size:.9rem;">history</span>
                                @_sharedResources[SharedResourcesKeys.Vendors_Experience]
                            </div>
                            <div class="info-value">
                                @if (Model.YearsExperience.HasValue)
                                {
                                    <span>@Model.YearsExperience @(isArabic ? "سنة" : "Years")</span>
                                }
                                else
                                {
                                    <span style="color:var(--muted)">—</span>
                                }
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.ShowroomAddressAr) || !string.IsNullOrWhiteSpace(Model.ShowroomAddressEn))
                        {
                            <div class="info-grid-full">
                                <div class="info-label">
                                    <span class="material-symbols-outlined" style="font-size:.9rem;">location_on</span>
                                    @_sharedResources[SharedResourcesKeys.Vendor_ShowroomAddress]
                                </div>
                                <div class="info-value">@(addressTxt ?? "—")</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Description Card -->
            @if (!string.IsNullOrWhiteSpace(Model.DescriptionAr) || !string.IsNullOrWhiteSpace(Model.DescriptionEn))
            {
                <div class="detail-card">
                    <div class="detail-card-header">
                        <div class="header-icon"><span class="material-symbols-outlined">description</span></div>
                        <h3>@_sharedResources[SharedResourcesKeys.Vendor_Description]</h3>
                    </div>
                    <div class="detail-card-body">
                        @if (!string.IsNullOrWhiteSpace(descriptionTxt))
                        {
                            <p class="desc-text">@descriptionTxt</p>
                        }
                        @{
                            var descAlt = isArabic ? Model.DescriptionEn : Model.DescriptionAr;
                        }
                        @if (!string.IsNullOrWhiteSpace(descAlt))
                        {
                            <p class="desc-text desc-alt">@descAlt</p>
                        }
                    </div>
                </div>
            }

            <!-- Showroom Image Card -->
            @if (Model.ShowroomImage != null)
            {
                <div class="detail-card">
                    <div class="detail-card-header">
                        <div class="header-icon"><span class="material-symbols-outlined">photo_camera</span></div>
                        <h3>@_sharedResources[SharedResourcesKeys.Vendor_ShowroomImage]</h3>
                    </div>
                    <div class="detail-card-body">
                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.ShowroomImage)"
                             alt="Showroom" class="showroom-img" />
                    </div>
                </div>
            }

        </div>

        <!-- Side Column -->
        <div class="detail-col-side">

            <!-- Status Card -->
            <div class="detail-card">
                <div class="detail-card-header">
                    <div class="header-icon"><span class="material-symbols-outlined">verified_user</span></div>
                    <h3>@_sharedResources[SharedResourcesKeys.Vendors_Status]</h3>
                </div>
                <div class="detail-card-body" style="text-align:center;padding:28px 24px;">
                    <div class="status-big @statusClass">
                        <span class="material-symbols-outlined">@statusIcon</span>
                        @statusLabel
                    </div>
                </div>
            </div>

            <!-- Documents Card -->
            <div class="detail-card">
                <div class="detail-card-header">
                    <div class="header-icon"><span class="material-symbols-outlined">folder_open</span></div>
                    <h3>@_sharedResources[SharedResourcesKeys.Vendor_Documents]</h3>
                </div>
                <div class="detail-card-body">
                    <div class="doc-list">
                        <!-- Commercial Registration -->
                        <div class="doc-item @(Model.CommercialRegistrationFile != null ? "doc-present" : "doc-missing")">
                            <span class="material-symbols-outlined">
                                @(Model.CommercialRegistrationFile != null ? "task_alt" : "description")
                            </span>
                            <div class="doc-info">
                                <div class="doc-name">@_sharedResources[SharedResourcesKeys.Vendor_CommercialReg]</div>
                                <div class="doc-status">
                                    @(Model.CommercialRegistrationFile != null
                                                                        ? (isArabic ? "✓ تم الرفع" : "✓ Uploaded")
                                                                        : (isArabic ? "✗ غير موجود" : "✗ Missing"))
                                </div>
                            </div>
                            @if (Model.CommercialRegistrationFile != null)
                            {
                                <a href="data:application/pdf;base64,@Convert.ToBase64String(Model.CommercialRegistrationFile)"
                                   download="commercial_registration_@(Model.Id).pdf"
                                   class="doc-download"
                                   title="@(isArabic ? "تحميل" : "Download")">
                                    <span class="material-symbols-outlined">download</span>
                                </a>
                            }
                        </div>

                        <!-- Work License -->
                        <div class="doc-item @(Model.WorkLicenseFile != null ? "doc-present" : "doc-missing")">
                            <span class="material-symbols-outlined">
                                @(Model.WorkLicenseFile != null ? "task_alt" : "badge")
                            </span>
                            <div class="doc-info">
                                <div class="doc-name">@_sharedResources[SharedResourcesKeys.Vendor_WorkLicense]</div>
                                <div class="doc-status">
                                    @(Model.WorkLicenseFile != null
                                                                        ? (isArabic ? "✓ تم الرفع" : "✓ Uploaded")
                                                                        : (isArabic ? "✗ غير موجود" : "✗ Missing"))
                                </div>
                            </div>
                            @if (Model.WorkLicenseFile != null)
                            {
                                <a href="data:application/pdf;base64,@Convert.ToBase64String(Model.WorkLicenseFile)"
                                   download="work_license_@(Model.Id).pdf"
                                   class="doc-download"
                                   title="@(isArabic ? "تحميل" : "Download")">
                                    <span class="material-symbols-outlined">download</span>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions Card -->
            <div class="detail-card">
                <div class="detail-card-header">
                    <div class="header-icon"><span class="material-symbols-outlined">bolt</span></div>
                    <h3>@(isArabic ? "إجراءات سريعة" : "Quick Actions")</h3>
                </div>
                <div class="detail-card-body quick-actions">
                    @if (Model.Verified != 1)
                    {
                        <button type="button" class="btn btn-success w-full"
                                onclick="confirmApprove(@Model.Id, '@Html.Raw(companyName.Replace("'", "\\'"))')">
                            <span class="material-symbols-outlined">check_circle</span>
                            @_sharedResources[SharedResourcesKeys.Vendors_Accept]
                        </button>
                    }
                    @if (Model.Verified != 2)
                    {
                        <button type="button" class="btn btn-danger w-full"
                                onclick="openRejectModal(@Model.Id, '@Html.Raw(companyName.Replace("'", "\\'"))')">
                            <span class="material-symbols-outlined">cancel</span>
                            @_sharedResources[SharedResourcesKeys.Vendors_Reject]
                        </button>
                    }
                    <a href="@Url.Action("Index", "VendorApplications")" class="btn btn-outline w-full">
                        <span class="material-symbols-outlined">@(isArabic ? "arrow_forward" : "arrow_back")</span>
                        @_sharedResources[SharedResourcesKeys.Back]
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal-overlay" id="rejectModal">
    <div class="modal-box">
        <div class="modal-title">
            <span class="material-symbols-outlined" style="color:#ef4444;">cancel</span>
            @_sharedResources[SharedResourcesKeys.Rejection_Title]
        </div>
        <div class="modal-sub">
            @_sharedResources[SharedResourcesKeys.Message_ConfirmReject]
            <span id="rejectCompanyName" class="modal-company-name"></span>
        </div>
        <hr class="modal-divider" />
        <div class="modal-label">@_sharedResources[SharedResourcesKeys.Rejection_ReasonAr]</div>
        <textarea class="modal-textarea" id="rejectReasonAr" placeholder="@_sharedResources[SharedResourcesKeys.Rejection_Reason]..." dir="rtl"></textarea>
        <div style="margin-top:12px;"></div>
        <div class="modal-label">@_sharedResources[SharedResourcesKeys.Rejection_ReasonEn]</div>
        <textarea class="modal-textarea" id="rejectReasonEn" placeholder="@_sharedResources[SharedResourcesKeys.Rejection_Reason]..." dir="ltr"></textarea>
        <div class="modal-footer">
            <button class="btn btn-outline btn-sm" onclick="closeRejectModal()">@_sharedResources[SharedResourcesKeys.Rejection_Cancel]</button>
            <button class="btn btn-danger btn-sm" onclick="submitReject()">
                <span class="material-symbols-outlined" style="font-size:1rem;">send</span>
                @_sharedResources[SharedResourcesKeys.Rejection_Submit]
            </button>
        </div>
    </div>
</div>

<!-- Confirm Dialog -->
<div class="confirm-overlay" id="confirmDialog">
    <div class="confirm-box">
        <div class="confirm-icon" id="confirmIcon"></div>
        <div class="confirm-title" id="confirmTitle"></div>
        <div class="confirm-sub" id="confirmSub"></div>
        <div class="confirm-actions">
            <button class="btn btn-outline btn-sm" onclick="closeConfirm()">
                @_sharedResources[SharedResourcesKeys.Rejection_Cancel]
            </button>
            <button class="btn btn-primary btn-sm" id="confirmOkBtn" onclick="confirmOk()"></button>
        </div>
    </div>
</div>

<!-- Toast Notifications -->
<div class="toast-wrap" id="toastWrap"></div>

<!-- Forms -->
<form id="approveForm" method="post" action="@Url.Action("Approve","VendorApplications")" style="display:none">
    @Html.AntiForgeryToken()
    <input type="hidden" id="approveVendorId" name="id" />
</form>
<form id="rejectForm" method="post" action="@Url.Action("Reject","VendorApplications")" style="display:none">
    @Html.AntiForgeryToken()
    <input type="hidden" id="rejectVendorId" name="id" />
    <input type="hidden" id="rejectReasonArInput" name="rejectionReasonAr" />
    <input type="hidden" id="rejectReasonEnInput" name="rejectionReasonEn" />
</form>

@section Scripts {
    <script src="~/js/jquery-3.7.1.min.js"></script>
    <script>
        var isArabic = @(isArabic ? "true" : "false");
        var currentRejectId = null;
        var _rejectAr = '', _rejectEn = '';
        var _confirmCallback = null;
        var msgReasonRequired = isArabic ? 'يرجى إدخال سبب الرفض' : 'Please enter a rejection reason';

        $(function () {
            var _ok  = '@Html.Raw(TempData["Success"] ?? "")';
            var _err = '@Html.Raw(TempData["Error"] ?? "")';
            if (_ok)  showToast(_ok,  'success');
            if (_err) showToast(_err, 'error');
        });

        function showConfirm(icon, title, sub, okLabel, okColor, callback) {
            document.getElementById('confirmIcon').textContent  = icon;
            document.getElementById('confirmTitle').textContent = title;
            document.getElementById('confirmSub').textContent   = sub;
            var btn = document.getElementById('confirmOkBtn');
            btn.textContent       = okLabel;
            btn.style.background  = okColor;
            btn.style.borderColor = okColor;
            _confirmCallback = callback;
            document.getElementById('confirmDialog').classList.add('open');
        }

        function closeConfirm() {
            document.getElementById('confirmDialog').classList.remove('open');
            _confirmCallback = null;
        }

        function confirmOk() {
            var cb = _confirmCallback;
            closeConfirm();
            if (cb) cb();
        }

        document.getElementById('confirmDialog').addEventListener('click', function (e) {
            if (e.target === this) closeConfirm();
        });

        function confirmApprove(id, name) {
            showConfirm('✅',
                isArabic ? 'تأكيد القبول' : 'Confirm Approval',
                (isArabic ? 'هل تريد قبول طلب: ' : 'Approve application for: ') + name + '؟',
                isArabic ? 'قبول' : 'Approve',
                '#10b981',
                function () {
                    document.getElementById('approveVendorId').value = id;
                    document.getElementById('approveForm').submit();
                }
            );
        }

        function openRejectModal(id, name) {
            currentRejectId = id;
            document.getElementById('rejectCompanyName').textContent = name;
            document.getElementById('rejectReasonAr').value = '';
            document.getElementById('rejectReasonEn').value = '';
            document.getElementById('rejectModal').classList.add('open');
        }

        function closeRejectModal() {
            document.getElementById('rejectModal').classList.remove('open');
        }

        function submitReject() {
            var ar = document.getElementById('rejectReasonAr').value.trim();
            var en = document.getElementById('rejectReasonEn').value.trim();
            if (!ar && !en) { showToast(msgReasonRequired, 'error'); return; }
            _rejectAr = ar; _rejectEn = en;
            var name = document.getElementById('rejectCompanyName').textContent;
            closeRejectModal();
            showConfirm('❌',
                isArabic ? 'تأكيد الرفض' : 'Confirm Rejection',
                (isArabic ? 'هل تريد رفض طلب: ' : 'Reject application for: ') + name + '؟',
                isArabic ? 'تأكيد الرفض' : 'Confirm Reject',
                '#ef4444',
                function () {
                    document.getElementById('rejectVendorId').value      = currentRejectId;
                    document.getElementById('rejectReasonArInput').value = _rejectAr;
                    document.getElementById('rejectReasonEnInput').value = _rejectEn;
                    document.getElementById('rejectForm').submit();
                }
            );
        }

        document.getElementById('rejectModal').addEventListener('click', function (e) {
            if (e.target === this) closeRejectModal();
        });

        function showToast(msg, type) {
            var icon = type === 'success' ? 'check_circle' : 'error';
            var $t = $('<div class="toast ' + type + '">' +
                       '<span class="material-symbols-outlined">' + icon + '</span>' +
                       '<span>' + msg + '</span></div>');
            $('#toastWrap').append($t);
            setTimeout(function () { $t.fadeOut(400, function () { $t.remove(); }); }, 4000);
        }
    </script>
}