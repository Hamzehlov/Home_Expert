<!-- ── Bottom Grid ── -->
<div class="bottom-grid">

    <!-- Recent Orders -->
    <div class="dash-card">
        <div class="dash-card-header">
            <span class="dash-card-title">@_sharedResources[SharedResourcesKeys.Recent_Orders]</span>
            <a href="@Url.Action("Index", "Orders")" class="dash-view-all">
                @_sharedResources[SharedResourcesKeys.View_All]
                <span class="material-symbols-outlined">arrow_back_ios</span>
            </a>
        </div>
        <table class="mini-table">
            <thead>
                <tr>
                    <th>@_sharedResources[SharedResourcesKeys.Col_Service]</th>
                    <th>@_sharedResources[SharedResourcesKeys.Col_Customer]</th>
                    <th>@_sharedResources[SharedResourcesKeys.Col_Status]</th>
                    <th>@_sharedResources[SharedResourcesKeys.Col_Amount]</th>
                </tr>
            </thead>
            <tbody>
                @* هون تحط foreach لو بتجيب البيانات من الـ Model *@
                <tr>
                    <td>
                        <div class="order-service">
                            <div class="order-thumb"><img src="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=80&q=80" alt="" /></div>
                            <div><div class="order-name">@_sharedResources[SharedResourcesKeys.Srv_FurnitureSale]</div><div class="order-id">#92841</div></div>
                        </div>
                    </td>
                    <td>إيلينا جيلبرت</td>
                    <td><span class="badge inprogress">@_sharedResources[SharedResourcesKeys.Status_InProgress]</span></td>
                    <td style="font-weight:800;color:#0A3D44;">1,450 ر.س</td>
                </tr>
                <tr>
                    <td>
                        <div class="order-service">
                            <div class="order-thumb"><img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=80&q=80" alt="" /></div>
                            <div><div class="order-name">@_sharedResources[SharedResourcesKeys.Srv_KitchenInstall]</div><div class="order-id">#92840</div></div>
                        </div>
                    </td>
                    <td>ماركوس رايت</td>
                    <td><span class="badge done">@_sharedResources[SharedResourcesKeys.Status_Done]</span></td>
                    <td style="font-weight:800;color:#0A3D44;">3,200 ر.س</td>
