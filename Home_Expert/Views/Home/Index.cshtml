                            <div class="dh-progress-top">
                                <span>@_sharedResources[SharedResourcesKeys.Lookup_LastQuery]</span>
                                <span class="dh-progress-pct">—</span>
                            </div>
                            <div class="dh-bar-bg"><div class="dh-bar-fill" style="width:0%"></div></div>
                        </div>
                    </div>
                    <div class="dh-foot">
                        <span class="dh-link">
                            @_sharedResources[SharedResourcesKeys.View_Details]
                            <span class="material-symbols-outlined">@(isArabic ? "arrow_back_ios" : "arrow_forward_ios")</span>
                        </span>
                    </div>
                </a>

                <a href="@Url.Action("IndexService", "Service")" class="dh-card t-c7">
                    <div class="dh-stripe"></div>
                    <div class="dh-head">
                        <div class="dh-icon"><span class="material-symbols-outlined"></span></div>
                        <span class="dh-badge active">@_sharedResources[SharedResourcesKeys.Srv_Active]</span>
                    </div>
                    <div class="dh-content">
                        <div class="dh-title">@_sharedResources[SharedResourcesKeys.Srv_Services]</div>
                        <div class="dh-desc">@_sharedResources[SharedResourcesKeys.Srv_Services_Desc]</div>
                        <div class="dh-metrics">
                            <div class="dh-metric">
                                <div class="dh-metric-val">120</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Srv_TotalOrders]</div>
                            </div>
                            <div class="dh-metric">
                                <div class="dh-metric-val">14</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Srv_ActiveOrders]</div>
                            </div>
                            <div class="dh-metric">
                                <div class="dh-metric-val">25k</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Srv_Sales]</div>
                            </div>
                        </div>
                        <div class="dh-progress">
                            <div class="dh-progress-top">
                                <span>@_sharedResources[SharedResourcesKeys.Srv_MonthProgress]</span>
                                <span class="dh-progress-pct">66%</span>
                            </div>
                            <div class="dh-bar-bg"><div class="dh-bar-fill" style="width:66%"></div></div>
                        </div>
                    </div>
                    <div class="dh-foot">
                        <span class="dh-link">
                            @_sharedResources[SharedResourcesKeys.View_Details]
                            <span class="material-symbols-outlined">@(isArabic ? "arrow_back_ios" : "arrow_forward_ios")</span>
                        </span>
                        <span class="dh-trend up"><span class="material-symbols-outlined">trending_up</span>+10%</span>
                    </div>
                </a>

                <a href="@Url.Action("IndexProduct", "Service")" class="dh-card t-c1">
                    <div class="dh-stripe"></div>
                    <div class="dh-head">
                        <div class="dh-icon"><span class="material-symbols-outlined">inventory_2</span></div>
                        <span class="dh-badge active">@_sharedResources[SharedResourcesKeys.Products_Active]</span>
                    </div>
                    <div class="dh-content">
                        <div class="dh-title">@_sharedResources[SharedResourcesKeys.Products_Title]</div>
                        <div class="dh-desc">@_sharedResources[SharedResourcesKeys.Products_Desc]</div>
                        <div class="dh-metrics">
                            <div class="dh-metric">
                                <div class="dh-metric-val">320</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Products_Total]</div>
                            </div>
                            <div class="dh-metric">
                                <div class="dh-metric-val">45</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Products_New]</div>
                            </div>
                            <div class="dh-metric">
                                <div class="dh-metric-val">12k</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Products_Sales]</div>
                            </div>
                        </div>
                    </div>
                    <div class="dh-foot">
                        <span class="dh-link">
                            @_sharedResources[SharedResourcesKeys.View_Details]
                            <span class="material-symbols-outlined">@(isArabic ? "arrow_back_ios" : "arrow_forward_ios")</span>
                        </span>
                    </div>
                </a>

            </div>
        
            <!-- /admin grid -->
        }

        @if (User.IsInRole("Vendor"))
        {
            <div class="dh-section" style="@(User.IsInRole("Admin") ? "margin-top:36px" : "margin-top:0")">
                <span class="dh-section-text">@(isArabic ? "لوحة المورد" : "Vendor Panel")</span>
                <div class="dh-section-line"></div>
                <span class="dh-section-pill">Vendor</span>
            </div>

            <div class="dh-grid">

                <a href="@Url.Action("MyServices", "Service")" class="dh-card t-c7">
                    <div class="dh-stripe"></div>
                    <div class="dh-head">
                        <div class="dh-icon"></div>
                        <span class="dh-badge active">@_sharedResources[SharedResourcesKeys.Srv_Active]</span>
                    </div>
                    <div class="dh-content">
                        <div class="dh-title">@_sharedResources[SharedResourcesKeys.Srv_Services]</div>
                        <div class="dh-desc">@_sharedResources[SharedResourcesKeys.Srv_Services_Desc]</div>
                        <div class="dh-metrics">
                            <div class="dh-metric">
                                <div class="dh-metric-val">120</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Srv_TotalOrders]</div>
                            </div>
                            <div class="dh-metric">
                                <div class="dh-metric-val">14</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Srv_ActiveOrders]</div>
                            </div>
                            <div class="dh-metric">
                                <div class="dh-metric-val">25k</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Srv_Sales]</div>
                            </div>
                        </div>
                        <div class="dh-progress">
                            <div class="dh-progress-top">
                                <span>@_sharedResources[SharedResourcesKeys.Srv_MonthProgress]</span>
                                <span class="dh-progress-pct">66%</span>
                            </div>
                            <div class="dh-bar-bg"><div class="dh-bar-fill" style="width:66%"></div></div>
                        </div>
                    </div>
                    <div class="dh-foot">
                        <span class="dh-link">
                            @_sharedResources[SharedResourcesKeys.View_Details]
                            <span class="material-symbols-outlined">@(isArabic ? "arrow_back_ios" : "arrow_forward_ios")</span>
                        </span>
                        <span class="dh-trend up"><span class="material-symbols-outlined">trending_up</span>+10%</span>
                    </div>
                </a>

                <a href="@Url.Action("Index", "ServiceOffers")" class="dh-card t-c1">
                    <div class="dh-stripe"></div>
                    <div class="dh-head">
                        <div class="dh-icon"><span class="material-symbols-outlined">inventory_2</span></div>
                        <span class="dh-badge active">@_sharedResources[SharedResourcesKeys.Products_Active]</span>
                    </div>
                    <div class="dh-content">
                        <div class="dh-title">@_sharedResources[SharedResourcesKeys.ServiceOffers_Title]</div>
                        <div class="dh-desc">@_sharedResources[SharedResourcesKeys.ServiceOffers_Desc]</div>
                        <div class="dh-metrics">
                            <div class="dh-metric">
                                <div class="dh-metric-val">320</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Products_Total]</div>
                            </div>
                            <div class="dh-metric">
                                <div class="dh-metric-val">45</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Products_New]</div>
                            </div>
                            <div class="dh-metric">
                                <div class="dh-metric-val">12k</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Products_Sales]</div>
                            </div>
                        </div>
                    </div>
                    <div class="dh-foot">
                        <span class="dh-link">
                            @_sharedResources[SharedResourcesKeys.View_Details]
                            <span class="material-symbols-outlined">@(isArabic ? "arrow_back_ios" : "arrow_forward_ios")</span>
                        </span>
                    </div>
                </a>


                <a href="@Url.Action("IndexProduct", "Service")" class="dh-card t-c1">
                    <div class="dh-stripe"></div>
                    <div class="dh-head">
                        <div class="dh-icon"><span class="material-symbols-outlined">inventory_2</span></div>
                        <span class="dh-badge active">@_sharedResources[SharedResourcesKeys.Products_Active]</span>
                    </div>
                    <div class="dh-content">
                        <div class="dh-title">@_sharedResources[SharedResourcesKeys.Products_Title]</div>
                        <div class="dh-desc">@_sharedResources[SharedResourcesKeys.Products_Desc]</div>
                        <div class="dh-metrics">
                            <div class="dh-metric">
                                <div class="dh-metric-val">320</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Products_Total]</div>
                            </div>
                            <div class="dh-metric">
                                <div class="dh-metric-val">45</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Products_New]</div>
                            </div>
                            <div class="dh-metric">
                                <div class="dh-metric-val">12k</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Products_Sales]</div>
                            </div>
                        </div>
                    </div>
                    <div class="dh-foot">
                        <span class="dh-link">
                            @_sharedResources[SharedResourcesKeys.View_Details]
                            <span class="material-symbols-outlined">@(isArabic ? "arrow_back_ios" : "arrow_forward_ios")</span>
                        </span>
                    </div>
                </a>

            </div>
        }

    </div></div>

@section Scripts {
    <script>
        // ── Live clock ──
        function dhUpdateClock() {
          var now  = new Date();
          var h    = String(now.getHours()).padStart(2,'0');
          var m    = String(now.getMinutes()).padStart(2,'0');
          var s    = String(now.getSeconds()).padStart(2,'0');
          var clk  = document.getElementById('dhClock');
          var dat  = document.getElementById('dhDate');
          if (clk) clk.textContent = h + ':' + m + ':' + s;
          if (dat) dat.textContent = now.toLocaleDateString('@(isArabic ? "ar-JO" : "en-GB")', {day:'numeric', month:'short'});
        }
        dhUpdateClock();
        setInterval(dhUpdateClock, 1000);
    </script>
}
