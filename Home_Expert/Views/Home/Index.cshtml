                    </div>
                    <div class="dh-content">
                        <div class="dh-title">@_sharedResources[SharedResourcesKeys.Lookup_Title]</div>
                        <div class="dh-desc">@_sharedResources[SharedResourcesKeys.Lookup_Desc]</div>
