@using Home_Expert.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> _sharedResources
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = _sharedResources[SharedResourcesKeys.Dashboard].Value;
    var isArabic = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}


<div class="dash-home">

    <div class="dh-welcome">
        <div class="dh-welcome-text">
            <h2>
                @{
                    var hour = DateTime.Now.Hour;
                    string greeting;
                    if (isArabic)
                        greeting = hour < 12 ? "صباح الخير" : hour < 17 ? "مساء الخير" : "أهلاً بك";
                    else
                        greeting = hour < 12 ? "Good Morning" : hour < 17 ? "Good Afternoon" : "Welcome Back";
                }
                @greeting 👋
            </h2>
            <p>@(isArabic ? "إليك ملخص نشاط المنصة اليوم" : "Here's what's happening on the platform today")</p>
            <div class="dh-welcome-time">
                <span class="material-symbols-outlined">schedule</span>
                <span id="dhClock"></span>
            </div>
        </div>
        <div class="dh-welcome-stats">
            @if (User.IsInRole("Admin"))
            {
                <div class="dh-wstat">
                    <div class="dh-wstat-val">@(ViewBag.TotalUsers ?? 0)</div>
                    <div class="dh-wstat-lbl">@(isArabic ? "المستخدمون" : "Users")</div>
                </div>
                <div class="dh-wstat-div"></div>
                <div class="dh-wstat">
                    <div class="dh-wstat-val">@(ViewBag.PendingCount ?? 0)</div>
                    <div class="dh-wstat-lbl">@(isArabic ? "طلبات معلقة" : "Pending")</div>
                </div>
                <div class="dh-wstat-div"></div>
            }
            <div class="dh-wstat">
                <div class="dh-wstat-val" id="dhDate"></div>
                <div class="dh-wstat-lbl">@(isArabic ? "اليوم" : "Today")</div>
            </div>
        </div>
    </div>

    <div class="dh-body">

        @if (User.IsInRole("Admin"))
        {
            <div class="dh-section">
                <span class="dh-section-text">@(isArabic ? "إدارة النظام" : "System Management")</span>
                <div class="dh-section-line"></div>
                <span class="dh-section-pill">Admin</span>
            </div>

            <div class="dh-grid">

                <a href="@Url.Action("Index", "VendorApplications")" class="dh-card t-vendor">
                    <div class="dh-stripe"></div>
                    <div class="dh-head">
                        <div class="dh-icon"><span class="material-symbols-outlined">business</span></div>
                        <span class="dh-badge @(ViewBag.PendingCount > 0 ? "warning" : "active")">
                            @ViewBag.PendingCount @_sharedResources[SharedResourcesKeys.Status_Pending]
                        </span>
                    </div>
                    <div class="dh-content">
                        <div class="dh-title">@_sharedResources[SharedResourcesKeys.PendingVendors_Title]</div>
                        <div class="dh-desc">@_sharedResources[SharedResourcesKeys.PendingVendors_Description]</div>
                        <div class="dh-metrics">
                            <div class="dh-metric">
                                <div class="dh-metric-val">@ViewBag.PendingCount</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Status_Pending]</div>
                            </div>
                            <div class="dh-metric">
                                <div class="dh-metric-val">@ViewBag.ApprovedCount</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Status_Approved]</div>
                            </div>
                            <div class="dh-metric">
                                <div class="dh-metric-val">@ViewBag.RejectedCount</div>
                                <div class="dh-metric-lbl">@_sharedResources[SharedResourcesKeys.Status_Rejected]</div>
                            </div>
                        </div>
                    </div>
                    <div class="dh-foot">
                        <span class="dh-link">
                            @_sharedResources[SharedResourcesKeys.View_Details]
                            <span class="material-symbols-outlined">@(isArabic ? "arrow_back_ios" : "arrow_forward_ios")</span>
                        </span>
                        <span class="dh-trend @(ViewBag.PendingCount > 5 ? "up" : "down")">
                            <span class="material-symbols-outlined">@(ViewBag.PendingCount > 5 ? "trending_up" : "trending_down")</span>
                            @ViewBag.PendingCount
                        </span>
                    </div>
                </a>

                <a href="@Url.Action("Index", "Users")" class="dh-card t-users">
                    <div class="dh-stripe"></div>
                    <div class="dh-head">
                        <div class="dh-icon"><span class="material-symbols-outlined">group</span></div>
                        <span class="dh-badge active">@(isArabic ? "نشط" : "Active")</span>
                    </div>
                    <div class="dh-content">
                        <div class="dh-title">@(isArabic ? "إدارة المستخدمين" : "Users Management")</div>
                        <div class="dh-desc">@(isArabic ? "عرض وإدارة جميع المستخدمين — عملاء وشركات ومديرين." : "View and manage all registered users — customers, vendors, and admins.")</div>
                        <div class="dh-metrics">
                            <div class="dh-metric">
                                <div class="dh-metric-val">@(ViewBag.TotalUsers ?? 0)</div>
                                <div class="dh-metric-lbl">@(isArabic ? "الكل" : "Total")</div>
                            </div>
                            <div class="dh-metric">
                                <div class="dh-metric-val">@(ViewBag.TotalVendors ?? 0)</div>
                                <div class="dh-metric-lbl">@(isArabic ? "شركات" : "Vendors")</div>
                            </div>
                            <div class="dh-metric">
                                <div class="dh-metric-val">@(ViewBag.TotalCustomers ?? 0)</div>
                                <div class="dh-metric-lbl">@(isArabic ? "عملاء" : "Customers")</div>
                            </div>
                        </div>
                    </div>
                    <div class="dh-foot">
                        <span class="dh-link">
                            @_sharedResources[SharedResourcesKeys.View_Details]
                            <span class="material-symbols-outlined">@(isArabic ? "arrow_back_ios" : "arrow_forward_ios")</span>
                        </span>
                        <span class="dh-trend up">
                            <span class="material-symbols-outlined">trending_up</span>
                            @(isArabic ? "نشط" : "Active")
                        </span>
                    </div>
                </a>

                <a href="@Url.Action("Index", "Service")" class="dh-card t-c2">
                    <div class="dh-stripe"></div>
                    <div class="dh-head">
                        <div class="dh-icon"><span class="material-symbols-outlined">campaign</span></div>
