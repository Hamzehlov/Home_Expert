                        </span>
                    </div>
                </a>

                <a href="@Url.Action("IndexCompanyType", "Service")" class="dh-card t-c3">
                    <div class="dh-stripe"></div>
                    <div class="dh-head">
                        <div class="dh-icon"><span class="material-symbols-outlined">search</span></div>
