@using Home_Expert.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> _sharedResources
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = _sharedResources[SharedResourcesKeys.Dashboard].Value;
    var isArabic = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}

<!-- ── Services Section ── -->
<div class="section-title">@_sharedResources[SharedResourcesKeys.Main_Services]</div>

<div class="services-grid">

    <!-- Vendor Applications Card -->
    <div class="srv-card vendor-card">
        <div class="srv-card-header">
            <div class="srv-top">
                <div class="srv-icon">
                    <span class="material-symbols-outlined">business</span>
                </div>
                <span class="srv-badge active">
                    @ViewBag.PendingCount @_sharedResources[SharedResourcesKeys.Status_Pending]
                </span>
            </div>
        </div>
        <div class="srv-body">
            <div class="srv-name">@_sharedResources[SharedResourcesKeys.PendingVendors_Title]</div>
            <div class="srv-desc">@_sharedResources[SharedResourcesKeys.PendingVendors_Description]</div>
            <div class="srv-stats">
                <div class="srv-stat-item">
                    <span class="srv-stat-val">@ViewBag.PendingCount</span>
                    <span class="srv-stat-label">@_sharedResources[SharedResourcesKeys.Status_Pending]</span>
                </div>
                <div class="srv-stat-item">
                    <span class="srv-stat-val">@ViewBag.ApprovedCount</span>
                    <span class="srv-stat-label">@_sharedResources[SharedResourcesKeys.Status_Approved]</span>
                </div>
                <div class="srv-stat-item">
                    <span class="srv-stat-val">@ViewBag.RejectedCount</span>
                    <span class="srv-stat-label">@_sharedResources[SharedResourcesKeys.Status_Rejected]</span>
                </div>
            </div>
            <div class="srv-progress-wrap">
                <div class="srv-progress-label">
                    <span>@_sharedResources[SharedResourcesKeys.Srv_MonthProgress]</span>
                    <span>@(ViewBag.PendingCount > 0 ? "⚠️" : "✅")</span>
                </div>
            </div>
        </div>
        <div class="srv-footer">
            <a href="@Url.Action("Index", "VendorApplications")" class="srv-link">
                @_sharedResources[SharedResourcesKeys.View_Details]
                <span class="material-symbols-outlined">arrow_back_ios</span>
            </a>
            <span class="srv-trend @(ViewBag.PendingCount > 5 ? "up" : "down")">
                <span class="material-symbols-outlined">@(ViewBag.PendingCount > 5 ? "trending_up" : "trending_down")</span>
                @ViewBag.PendingCount
            </span>
        </div>
    </div>

