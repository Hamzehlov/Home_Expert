@using Home_Expert.ViewModel
@model ServiceOfferDetailsVm
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isArabic = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar");
    var dir      = isArabic ? "rtl" : "ltr";
    var custName = (isArabic ? Model.CustomerNameAr : Model.CustomerNameEn).Trim();
    if (string.IsNullOrWhiteSpace(custName)) custName = isArabic ? "عميل" : "Customer";
    var svcName  = isArabic ? Model.ServiceNameAr : Model.ServiceNameEn;
    var svcType  = isArabic ? Model.ServiceTypeAr : Model.ServiceTypeEn;
    var svcCat   = isArabic ? Model.ServiceCatAr  : Model.ServiceCatEn;
    var offerSt  = isArabic ? Model.OfferStatusAr  : Model.OfferStatusEn;
    var reqSt    = isArabic ? Model.RequestStatusAr : Model.RequestStatusEn;
    
    string GetStatusKey(int statusId) => statusId switch
    {
        86 => "pending",
        87 => "submitted",
        88 => "accepted",
        89 => "rejected",
        _ => "pending"
    };
    
    bool CanSubmitOffer(int offerStatusId, int requestStatusId)
    {
        int REQUEST_ACCEPTED = 81;
        int REQUEST_REJECTED = 82;
        int OFFER_ACCEPTED = 88;
        int OFFER_REJECTED = 89;
        
        return offerStatusId != OFFER_ACCEPTED &&
               offerStatusId != OFFER_REJECTED &&
               requestStatusId != REQUEST_ACCEPTED &&
               requestStatusId != REQUEST_REJECTED;
    }
    
    var statusKey = GetStatusKey(Model.OfferStatusId);
    var canSubmit = CanSubmitOffer(Model.OfferStatusId, Model.RequestStatusId);
}

@section Styles {
<style>
/* ═══════════════════════════ sod-page ═══════════════════════════ */
.sod-page { padding:24px 24px 56px; max-width:1200px; margin:0 auto; }

.sod-breadcrumb { display:flex;align-items:center;gap:5px;font-size:.75rem;color:var(--muted);margin-bottom:8px;flex-wrap:wrap; }
.sod-breadcrumb a { color:var(--muted);text-decoration:none;font-weight:600;transition:color .18s; }
.sod-breadcrumb a:hover { color:var(--primary); }
.sod-breadcrumb .sep { font-size:14px;opacity:.4; }

/* Hero */
.sod-hero {
  background:linear-gradient(135deg,var(--primary) 0%,#0d5562 100%);
  border-radius:20px;padding:26px 32px;
  display:flex;align-items:center;gap:20px;
  margin-bottom:24px;position:relative;overflow:hidden;
  box-shadow:0 8px 32px rgba(10,61,68,.2);
  flex-wrap:wrap;
}
.sod-hero::before { content:'';position:absolute;width:200px;height:200px;border-radius:50%;background:rgba(197,160,89,.1);filter:blur(50px);top:-60px; }
html[dir="rtl"] .sod-hero::before { left:-40px; } html[dir="ltr"] .sod-hero::before { right:-40px; }
.sod-hero-icon { width:68px;height:68px;border-radius:16px;background:rgba(255,255,255,.18);backdrop-filter:blur(10px);border:2px solid rgba(255,255,255,.3);display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;z-index:1; }
.sod-hero-icon .material-symbols-outlined { font-size:30px;color:#fff; }
.sod-hero-text { flex:1;min-width:0;position:relative;z-index:1; }
.sod-hero-title { font-size:1.3rem;font-weight:900;color:#fff;margin:0 0 4px;line-height:1.2; }
.sod-hero-sub   { font-size:.82rem;color:rgba(255,255,255,.7);margin:0 0 10px; }
.sod-hero-badges { display:flex;gap:8px;flex-wrap:wrap; }
.sod-hbadge { display:inline-flex;align-items:center;gap:5px;font-size:.65rem;font-weight:800;padding:4px 12px;border-radius:999px;text-transform:uppercase;letter-spacing:.05em;background:rgba(255,255,255,.18);color:#fff;border:1px solid rgba(255,255,255,.25);backdrop-filter:blur(8px); }
.sod-hbadge .material-symbols-outlined { font-size:12px; }
.sod-hero-actions { display:flex;gap:10px;flex-wrap:wrap;position:relative;z-index:1; }

.sod-back-btn { display:inline-flex;align-items:center;gap:7px;padding:10px 18px;border-radius:11px;background:rgba(255,255,255,.18);color:#fff;border:1.5px solid rgba(255,255,255,.3);font-size:.84rem;font-weight:700;text-decoration:none;transition:all .2s;backdrop-filter:blur(8px);white-space:nowrap; }
.sod-back-btn:hover { background:rgba(255,255,255,.3);color:#fff; }
.sod-back-btn .material-symbols-outlined { font-size:16px; }

/* Grid */
.sod-grid { display:grid;grid-template-columns:1fr 380px;gap:20px;align-items:start; }
.sod-col  { display:flex;flex-direction:column;gap:18px; }

/* Cards */
.sod-card { background:#fff;border-radius:18px;border:1.5px solid var(--border);box-shadow:0 2px 10px rgba(0,0,0,.04);overflow:hidden; }
.sod-card-head { display:flex;align-items:center;gap:12px;padding:16px 20px;border-bottom:1.5px solid var(--border);background:#fafbfc; }
.sod-card-icon { width:38px;height:38px;border-radius:10px;background:rgba(10,61,68,.08);color:var(--primary);display:flex;align-items:center;justify-content:center;flex-shrink:0; }
.sod-card-icon .material-symbols-outlined { font-size:19px; }
.sod-card-title { font-size:.95rem;font-weight:800;color:var(--primary);margin:0; }
.sod-card-body { padding:20px; }

/* Info grid */
.sod-info { display:grid;grid-template-columns:repeat(2,1fr);gap:16px; }
.sod-info-full { grid-column:1/-1; }
.sod-lbl { font-size:.63rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);display:flex;align-items:center;gap:5px;margin-bottom:5px; }
.sod-lbl .material-symbols-outlined { font-size:12px; }
.sod-val { font-size:.9rem;font-weight:700;color:var(--text);line-height:1.45;word-break:break-word; }
.sod-val.empty { color:var(--muted);font-style:italic;font-weight:400;font-size:.82rem; }

/* Status badge */
.sod-badge { display:inline-flex;align-items:center;gap:5px;font-size:.72rem;font-weight:800;padding:6px 14px;border-radius:999px;text-transform:uppercase;letter-spacing:.04em; }
.sod-badge.pending   { background:rgba(245,158,11,.1); color:#b45309; border:1.5px solid rgba(245,158,11,.22); }
.sod-badge.submitted { background:rgba(59,130,246,.1); color:#2563eb; border:1.5px solid rgba(59,130,246,.22); }
.sod-badge.accepted  { background:rgba(16,185,129,.1); color:#059669; border:1.5px solid rgba(16,185,129,.22); }
.sod-badge.rejected  { background:rgba(239,68,68,.1);  color:#dc2626; border:1.5px solid rgba(239,68,68,.2);  }
.sod-badge .material-symbols-outlined { font-size:14px; }

/* Kitchen & Moving specific styles */
.sod-details-grid { display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:8px; }
.sod-detail-item { border-bottom:1px solid var(--border);padding:8px 0; }
.sod-detail-label { font-size:.7rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px;display:flex;align-items:center;gap:5px; }
.sod-detail-value { font-size:.85rem;font-weight:600;color:var(--text); }
.sod-price-value { font-size:1.2rem;font-weight:900;color:var(--primary); }
.sod-section-title { font-size:.85rem;font-weight:800;color:var(--primary);margin:16px 0 12px 0;padding-bottom:6px;border-bottom:2px solid var(--border);display:flex;align-items:center;gap:8px; }
.sod-section-title .material-symbols-outlined { font-size:18px; }

/* Price big */
.sod-price-big { font-size:2rem;font-weight:900;color:var(--primary);line-height:1; }
.sod-price-currency { font-size:.9rem;font-weight:600;color:var(--muted); }

/* Map */
.sod-map {
  width:100%;height:160px;border-radius:12px;
  background:linear-gradient(135deg,#f0fdf4,#dcfce7);
  border:1.5px solid #bbf7d0;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;
  color:var(--primary);margin-top:12px;
}
.sod-map .material-symbols-outlined { font-size:2rem;opacity:.5; }
.sod-map-coords { font-size:.72rem;color:var(--muted);font-family:monospace; }

/* Offer Form */
.sod-form-field { margin-bottom:16px; }
.sod-form-label { font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--text);display:flex;align-items:center;gap:6px;margin-bottom:7px; }
.sod-form-label .material-symbols-outlined { font-size:14px;color:var(--primary); }
.sod-input-wrap { display:flex;align-items:center;background:#f8fafc;border:1.5px solid var(--border);border-radius:12px;overflow:hidden;transition:border-color .2s,box-shadow .2s; }
.sod-input-wrap:focus-within { border-color:var(--primary);box-shadow:0 0 0 3px rgba(10,61,68,.07);background:#fff; }
.sod-input-wrap.has-error { border-color:#ef4444; }
.sod-inp-icon { width:44px;height:44px;display:flex;align-items:center;justify-content:center;color:var(--muted);flex-shrink:0; }
.sod-inp-icon .material-symbols-outlined { font-size:17px; }
.sod-input { flex:1;border:none;background:transparent;outline:none;font-size:.9rem;font-family:inherit;color:var(--text);height:44px;padding-inline-end:14px; }
html[dir="ltr"] .sod-input { padding-inline-start:0; }
.sod-input::placeholder { color:#b0b8c4; }
.sod-input:disabled { color:var(--muted);cursor:not-allowed; }
.sod-input[type="file"] { padding-block: 10px; cursor: pointer; }
.sod-input[type="file"]:disabled { cursor: not-allowed; opacity: 0.6; }
.sod-input[type="file"]::file-selector-button { background: var(--primary); color: white; border: none; border-radius: 8px; padding: 6px 12px; margin-inline-end: 12px; font-family: inherit; font-weight: 600; cursor: pointer; transition: background 0.2s; }
.sod-input[type="file"]::file-selector-button:hover { background: #0d5562; }

.sod-toggle-row { display:flex;align-items:center;justify-content:space-between;padding:13px 16px;background:#f8fafc;border-radius:12px;border:1.5px solid var(--border); }
.sod-toggle-lbl { font-size:.86rem;font-weight:700;color:var(--text);display:flex;align-items:center;gap:8px; }
.sod-toggle-lbl .material-symbols-outlined { font-size:17px;color:var(--primary); }
.sod-toggle-sub { font-size:.7rem;color:var(--muted);margin-top:2px; }
.sod-switch { position:relative;width:44px;height:24px;flex-shrink:0; }
.sod-switch input { opacity:0;width:0;height:0; }
.sod-slider { position:absolute;inset:0;background:#cbd5e1;border-radius:999px;cursor:pointer;transition:background .25s; }
.sod-slider::before { content:'';position:absolute;width:18px;height:18px;border-radius:50%;background:#fff;top:3px;transition:transform .25s;box-shadow:0 1px 4px rgba(0,0,0,.2); }
html[dir="rtl"] .sod-slider::before { right:3px; } html[dir="ltr"] .sod-slider::before { left:3px; }
.sod-switch input:checked + .sod-slider { background:var(--primary); }
html[dir="rtl"] .sod-switch input:checked + .sod-slider::before { transform:translateX(-20px); }
html[dir="ltr"] .sod-switch input:checked + .sod-slider::before { transform:translateX(20px); }

.sod-err { font-size:.7rem;color:#dc2626;margin-top:5px;display:flex;align-items:center;gap:4px; }
.sod-submit-btn { display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:13px;border-radius:12px;background:linear-gradient(135deg,var(--primary),#0d5562);color:#fff;font-size:.9rem;font-weight:800;border:none;cursor:pointer;font-family:inherit;box-shadow:0 4px 16px rgba(10,61,68,.22);transition:all .25s;margin-top:4px; }
.sod-submit-btn:hover { transform:translateY(-2px);box-shadow:0 8px 24px rgba(10,61,68,.3); }
.sod-submit-btn:disabled { opacity:.6;cursor:not-allowed;transform:none; }

/* Attachment */
.sod-attachment-viewer { margin-top: 20px; border-top: 1.5px solid var(--border); padding-top: 16px; }
.sod-attachment-preview { background: #f8fafc; border-radius: 12px; border: 1.5px solid var(--border); overflow: hidden; }
.sod-attachment-preview iframe { width: 100%; height: 400px; border: none; }
.sod-attachment-preview img { width: 100%; max-height: 400px; object-fit: contain; display: block; }
.sod-attachment-actions { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; padding: 12px 16px; background: #fff; border-top: 1.5px solid var(--border); }
.sod-attachment-filename { display: flex; align-items: center; gap: 6px; font-size: .8rem; color: var(--text); font-family: monospace; }
.sod-no-attachment { background: #f8fafc; border-radius: 12px; border: 1.5px dashed var(--border); padding: 32px; text-align: center; color: var(--muted); }

/* Toasts */
.sod-toasts { position:fixed;bottom:22px;z-index:9999;display:flex;flex-direction:column;gap:10px;pointer-events:none; }
html[dir="rtl"] .sod-toasts { right:22px; } html[dir="ltr"] .sod-toasts { left:22px; }
.sod-toast { display:flex;align-items:center;gap:10px;padding:12px 18px;border-radius:13px;font-size:.84rem;font-weight:600;color:#fff;box-shadow:0 8px 26px rgba(0,0,0,.17);pointer-events:all;min-width:210px;max-width:330px;animation:sodToastIn .3s ease; }
@@keyframes sodToastIn { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:none} }
.sod-toast.success { background:#059669; } .sod-toast.error { background:#dc2626; }

@@media(max-width:900px) {
  .sod-grid { grid-template-columns:1fr; }
  .sod-col:last-child { order:-1; }
}
@@media(max-width:600px) {
  .sod-page { padding:14px 12px 40px; }
  .sod-hero { padding:20px 18px; gap:14px; }
  .sod-info { grid-template-columns:1fr; }
  .sod-details-grid { grid-template-columns:1fr; }
}
</style>
}

<div class="sod-page" dir="@dir">

  <div class="sod-breadcrumb" style="margin-bottom:14px;">
    <a href="@Url.Action("Index","Home")">
      <span class="material-symbols-outlined" style="font-size:.9rem;vertical-align:middle;">home</span>
      @(isArabic?"لوحة التحكم":"Dashboard")
    </a>
    <span class="material-symbols-outlined sep">@(isArabic?"chevron_left":"chevron_right")</span>
    <a href="@Url.Action("Index","ServiceOffers")">@(isArabic?"طلبات الخدمات":"Service Requests")</a>
    <span class="material-symbols-outlined sep">@(isArabic?"chevron_left":"chevron_right")</span>
    <span>@(isArabic?"تفاصيل الطلب":"Request Details")</span>
  </div>

  <div class="sod-hero">
    <div class="sod-hero-icon"><span class="material-symbols-outlined">handyman</span></div>
    <div class="sod-hero-text">
      <div class="sod-hero-title">@svcName</div>
      <div class="sod-hero-sub">@svcType @(string.IsNullOrWhiteSpace(svcCat) ? "" : "· " + svcCat)</div>
      <div class="sod-hero-badges">
        <span class="sod-hbadge"><span class="material-symbols-outlined">tag</span>@(isArabic?"طلب رقم":"Request #")@Model.RequestId</span>
        <span class="sod-hbadge"><span class="material-symbols-outlined">receipt_long</span>@(isArabic?"عرض رقم":"Offer #")@Model.OfferId</span>
        @if (Model.PreferredTime.HasValue) {
          <span class="sod-hbadge"><span class="material-symbols-outlined">schedule</span>@Model.PreferredTime.Value.ToString("dd/MM/yyyy hh:mm tt")</span>
        }
      </div>
    </div>
    <div class="sod-hero-actions">
      <a href="@Url.Action("Index","ServiceOffers")" class="sod-back-btn">
        <span class="material-symbols-outlined">@(isArabic?"arrow_forward":"arrow_back")</span>
        @(isArabic?"رجوع":"Back")
      </a>
    </div>
  </div>

  <div class="sod-grid">

    <div class="sod-col">

      <!-- Service Details Card -->
      <div class="sod-card">
        <div class="sod-card-head">
          <div class="sod-card-icon"><span class="material-symbols-outlined">home_repair_service</span></div>
          <h3 class="sod-card-title">@(isArabic?"تفاصيل الخدمة":"Service Details")</h3>
        </div>
        <div class="sod-card-body">
          <div class="sod-info">
            <div><div class="sod-lbl"><span class="material-symbols-outlined">translate</span>@(isArabic?"الاسم عربي":"Arabic Name")</div><div class="sod-val">@Model.ServiceNameAr</div></div>
            <div><div class="sod-lbl"><span class="material-symbols-outlined">language</span>@(isArabic?"الاسم إنجليزي":"English Name")</div><div class="sod-val">@Model.ServiceNameEn</div></div>
            <div><div class="sod-lbl"><span class="material-symbols-outlined">category</span>@(isArabic?"النوع":"Type")</div><div class="sod-val">@(string.IsNullOrWhiteSpace(svcType) ? "—" : svcType)</div></div>
            <div><div class="sod-lbl"><span class="material-symbols-outlined">folder</span>@(isArabic?"التصنيف":"Category")</div><div class="sod-val @(string.IsNullOrWhiteSpace(svcCat) ? "empty" : "")">@(string.IsNullOrWhiteSpace(svcCat) ? (isArabic?"غير محدد":"Not set") : svcCat)</div></div>
            <div><div class="sod-lbl"><span class="material-symbols-outlined">schedule</span>@(isArabic?"الوقت المفضل":"Preferred Time")</div><div class="sod-val @(!Model.PreferredTime.HasValue ? "empty" : "")">@(Model.PreferredTime.HasValue ? Model.PreferredTime.Value.ToString("dd/MM/yyyy — hh:mm tt") : (isArabic?"غير محدد":"Not specified"))</div></div>
            <div><div class="sod-lbl"><span class="material-symbols-outlined">info</span>@(isArabic?"حالة الطلب":"Request Status")</div><div><span class="sod-badge @statusKey"><span class="material-symbols-outlined">circle</span>@reqSt</span></div></div>
          </div>
        </div>
      </div>

      <!-- Customer Information Card -->
      <div class="sod-card">
        <div class="sod-card-head">
          <div class="sod-card-icon"><span class="material-symbols-outlined">person</span></div>
          <h3 class="sod-card-title">@(isArabic?"معلومات العميل":"Customer Information")</h3>
        </div>
        <div class="sod-card-body">
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px;">
            <div class="sod-cust-av">@(custName.Length > 0 ? custName[0].ToString().ToUpper() : "?")</div>
            <div><div style="font-size:1rem;font-weight:800;color:var(--text);">@custName</div><div style="font-size:.8rem;color:var(--muted);">@Model.CustomerEmail</div></div>
          </div>
          <div class="sod-info">
            <div><div class="sod-lbl"><span class="material-symbols-outlined">call</span>@(isArabic?"الهاتف":"Phone")</div><div class="sod-val @(string.IsNullOrWhiteSpace(Model.CustomerPhone) ? "empty" : "")" dir="ltr">@(string.IsNullOrWhiteSpace(Model.CustomerPhone) ? (isArabic?"غير متوفر":"N/A") : Model.CustomerPhone)</div></div>
            <div><div class="sod-lbl"><span class="material-symbols-outlined">location_city</span>@(isArabic?"المدينة":"City")</div><div class="sod-val @(string.IsNullOrWhiteSpace(Model.CustomerCity) ? "empty" : "")">@(string.IsNullOrWhiteSpace(Model.CustomerCity) ? (isArabic?"غير محدد":"N/A") : Model.CustomerCity)</div></div>
            <div class="sod-info-full"><div class="sod-lbl"><span class="material-symbols-outlined">location_on</span>@(isArabic?"المنطقة":"Area")</div><div class="sod-val @(string.IsNullOrWhiteSpace(Model.CustomerArea) ? "empty" : "")">@(string.IsNullOrWhiteSpace(Model.CustomerArea) ? (isArabic?"غير محدد":"N/A") : Model.CustomerArea)</div></div>
          </div>
          @if (Model.CustomerLatitude.HasValue && Model.CustomerLongitude.HasValue) {
            <div class="sod-map">
              <span class="material-symbols-outlined">map</span>
              <div class="sod-map-coords">@Model.CustomerLatitude.Value.ToString("F6"), @Model.CustomerLongitude.Value.ToString("F6")</div>
              <a href="https://maps.google.com?q=@Model.CustomerLatitude,@Model.CustomerLongitude" target="_blank" style="font-size:.78rem;font-weight:700;color:var(--primary);text-decoration:none;display:flex;align-items:center;gap:5px;"><span class="material-symbols-outlined" style="font-size:15px;">open_in_new</span>@(isArabic?"فتح في خرائط Google":"Open in Google Maps")</a>
            </div>
          }
        </div>
      </div>

   <!-- ========================================================= -->
<!-- قسم تفاصيل المطابخ (يظهر فقط إذا كانت الخدمة مطابخ)        -->
<!-- ========================================================= -->
@if (Model.IsKitchenService)
{
    <div class="sod-card">
        <div class="sod-card-head">
            <div class="sod-card-icon"><span class="material-symbols-outlined">kitchen</span></div>
            <h3 class="sod-card-title">@(isArabic?"تفاصيل المطبخ":"Kitchen Details")</h3>
        </div>
        <div class="sod-card-body">
            
            @if (Model.KitchenMeasurement != null)
            {
                <!-- قياسات المطبخ -->
                <div class="sod-section-title">
                    <span class="material-symbols-outlined">straighten</span>
                    @(isArabic ? "بيانات القياس" : "Measurement Data")
                </div>
                <div class="sod-details-grid">
                    <div class="sod-detail-item">
                        <div class="sod-detail-label"><span class="material-symbols-outlined">edit_note</span>@(isArabic?"طريقة الإدخال":"Input Mode")</div>
                        <div class="sod-detail-value">@(isArabic ? Model.KitchenMeasurement.InputMode?.DescCodeAr : Model.KitchenMeasurement.InputMode?.DescCodeEn)</div>
                    </div>
                    <div class="sod-detail-item">
                        <div class="sod-detail-label"><span class="material-symbols-outlined">straighten</span>@(isArabic?"وحدة القياس":"Unit")</div>
                        <div class="sod-detail-value">@(isArabic ? Model.KitchenMeasurement.Unit?.DescCodeAr : Model.KitchenMeasurement.Unit?.DescCodeEn)</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.KitchenMeasurement.RawData))
                    {
                        <div class="sod-info-full">
                            <div class="sod-detail-label"><span class="material-symbols-outlined">data_array</span>@(isArabic?"بيانات القياس الخام":"Raw Data")</div>
