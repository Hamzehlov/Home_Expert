<div class="sod-toasts" id="sodToasts"></div>

<form id="sodForm" method="post" action="@Url.Action("SubmitOffer","ServiceOffers")" style="display:none" enctype="multipart/form-data">
  @Html.AntiForgeryToken()
  <input type="hidden" name="offerId" id="formOfferId" />
  <input type="hidden" name="priceEstimate" id="formPriceEstimate" />
  <input type="hidden" name="inspectionRequired" id="formInspectionRequired" />
</form>

@section Scripts {
<script>
var isArabic = @(isArabic ? "true" : "false");
var OFFER_ID = @Model.OfferId;

async function submitOffer() {
    var price      = parseFloat(document.getElementById('sodPrice').value);
    var inspection = document.getElementById('sodInspection').checked;
    var fileInput  = document.getElementById('sodAttachment');
    var file       = fileInput.files[0];

    document.getElementById('sodPriceWrap')?.classList.remove('has-error');
    document.getElementById('sodPriceErr').style.display = 'none';
    document.getElementById('sodFileErr').style.display = 'none';

    if (!price || price <= 0) {
        document.getElementById('sodPriceWrap').classList.add('has-error');
        document.getElementById('sodPriceErr').style.display  = 'flex';
        document.getElementById('sodPriceErrMsg').textContent = isArabic ? 'يرجى إدخال سعر صحيح' : 'Please enter a valid price';
        return;
    }

    if (file && file.size > 5 * 1024 * 1024) {
        document.getElementById('sodFileErr').style.display = 'flex';
        document.getElementById('sodFileErrMsg').textContent = isArabic ? 'حجم الملف يتجاوز 5 ميجابايت' : 'File size exceeds 5MB';
        return;
    }

    if (file) {
        var allowedExts = ['.pdf', '.doc', '.docx', '.jpg', '.jpeg', '.png'];
        var fileName = file.name;
        var ext = '.' + fileName.split('.').pop().toLowerCase();
        if (!allowedExts.includes(ext)) {
            document.getElementById('sodFileErr').style.display = 'flex';
            document.getElementById('sodFileErrMsg').textContent = isArabic ? 'نوع الملف غير مسموح. المسموح: PDF, Word, صور' : 'File type not allowed. Allowed: PDF, Word, Images';
            return;
        }
    }

    var btn   = document.getElementById('sodSubmitBtn');
    btn.disabled = true;
    btn._orig    = btn.innerHTML;
    btn.innerHTML = '<span class="material-symbols-outlined" style="animation:sodSpin 1s linear infinite">autorenew</span> ' + (isArabic ? 'جاري الإرسال...' : 'Sending...');

    var formData = new FormData();
    formData.append('offerId', OFFER_ID);
    formData.append('priceEstimate', price);
    formData.append('inspectionRequired', inspection);
    if (file) formData.append('attachmentFile', file);

    var token = document.querySelector('#sodForm input[name="__RequestVerificationToken"]').value;

    try {
        var res = await fetch('@Url.Action("SubmitOffer","ServiceOffers")', {
            method: 'POST',
            headers: { 'RequestVerificationToken': token },
            body: formData
        });
        var data = await res.json();

        if (res.ok && (data.success || data.Success)) {
            sodToast(data.message || (isArabic ? 'تم تقديم العرض بنجاح' : 'Offer submitted successfully'), 'success');
            setTimeout(function () { location.reload(); }, 1500);
        } else {
            sodToast(data.message || (isArabic ? 'حدث خطأ' : 'An error occurred'), 'error');
            btn.disabled  = false;
            btn.innerHTML = btn._orig;
        }
    } catch(e) {
        sodToast(isArabic ? 'خطأ في الاتصال' : 'Connection error', 'error');
        btn.disabled  = false;
        btn.innerHTML = btn._orig;
    }
}

function sodToast(msg, type) {
    var el = document.createElement('div');
    el.className = 'sod-toast ' + type;
    el.innerHTML = '<span class="material-symbols-outlined">' + (type==='success'?'check_circle':'error') + '</span><span>' + msg + '</span>';
    document.getElementById('sodToasts').appendChild(el);
    setTimeout(function(){ el.style.transition='opacity .4s'; el.style.opacity='0'; setTimeout(function(){el.remove();},420); }, 3800);
}

document.head.insertAdjacentHTML('beforeend','<style>@@keyframes sodSpin{to{transform:rotate(360deg)}}</style>');
</script>
}