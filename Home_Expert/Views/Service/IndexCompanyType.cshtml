@model IEnumerable<Home_Expert.Models.Code>
@using Home_Expert.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> _sharedResources

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isArabic = culture.StartsWith("ar");
    var tableDir = isArabic ? "rtl" : "ltr";
}

@section Styles {
    <link rel="stylesheet" href="~/css/table.css" />
    <link href="~/lib/datatable/datatable.min.css" rel="stylesheet" />
}

<div class="page-wrapper">

    <div class="page-header">
        <div class="page-header-text">
            <div class="breadcrumb">
                <a href="@Url.Action("Index", "Home")">@_sharedResources[SharedResourcesKeys.Dashboard]</a>
                <span class="material-symbols-outlined sep">@(isArabic ? "chevron_left" : "chevron_right")</span>
                <span>@_sharedResources[SharedResourcesKeys.CompanyTypes_Title]</span>
            </div>
            <h1>@_sharedResources[SharedResourcesKeys.CompanyTypes_Title]</h1>
            <p>@_sharedResources[SharedResourcesKeys.CompanyTypes_Description]</p>
        </div>
    </div>

    <div class="stats-row">
        <div class="stat-pill">
            <div class="stat-pill-icon" style="background:rgba(10,61,68,.1);color:#0A3D44;">
                <span class="material-symbols-outlined">business</span>
            </div>
            <div>
                <div class="stat-pill-val">@Model.Count()</div>
                <div class="stat-pill-label">@_sharedResources[SharedResourcesKeys.CompanyTypes_Total]</div>
            </div>
        </div>
        <div class="stat-pill">
            <div class="stat-pill-icon green">
                <span class="material-symbols-outlined">check_circle</span>
            </div>
            <div>
                <div class="stat-pill-val">@Model.Count(c => c.IsActive == true)</div>
                <div class="stat-pill-label">@_sharedResources[SharedResourcesKeys.CompanyTypes_Active]</div>
            </div>
        </div>
        <div class="stat-pill">
            <div class="stat-pill-icon red">
                <span class="material-symbols-outlined">cancel</span>
            </div>
            <div>
                <div class="stat-pill-val">@Model.Count(c => c.IsActive == false)</div>
                <div class="stat-pill-label">@_sharedResources[SharedResourcesKeys.CompanyTypes_Inactive]</div>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="table-toolbar-extra">
            <a class="btn btn-primary" asp-action="CreateCompanyType">
                <span class="material-symbols-outlined">add</span>
                @_sharedResources[SharedResourcesKeys.CompanyTypes_AddNew]
            </a>
            <select class="tbl-filter" id="statusFilter">
                <option value="">@_sharedResources[SharedResourcesKeys.Filter_AllStatus]</option>
                <option value="active">@_sharedResources[SharedResourcesKeys.CompanyTypes_Active]</option>
                <option value="inactive">@_sharedResources[SharedResourcesKeys.CompanyTypes_Inactive]</option>
            </select>
        </div>

        <table id="companyTypesTable" class="data-table" style="width:100%" dir="@tableDir">
            <thead>
                <tr>
                    <th>#</th>
                    <th>@_sharedResources[SharedResourcesKeys.CompanyTypes_Name]</th>
                    <th>@_sharedResources[SharedResourcesKeys.CompanyTypes_Status]</th>
                    <th>@_sharedResources[SharedResourcesKeys.CompanyTypes_Actions]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var type in Model)
                {
                    var statusKey = type.IsActive == true ? "active" : "inactive";
                    <tr data-status="@statusKey">
                        <td class="row-num" style="font-weight:700;color:var(--primary);"></td>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">
                                    @if (type.Image != null && type.Image.Length > 0)
                                    {
                                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(type.Image)" alt="Company Image" />
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined">image_not_supported</span>
                                    }
                                </div>
                                <div>
                                    <div class="company-name">@((isArabic) ? type.DescCodeAr : type.DescCodeEn)</div>
                                    <div class="company-other-name" style="font-size:.75rem;color:var(--muted);">
                                        @type.Type
                                    </div>
                                </div>
                            </div>
                        </td>

                        <td data-search="@statusKey">
                            @if (type.IsActive == true)
                            {
                                <span class="status-badge active">@_sharedResources[SharedResourcesKeys.CompanyTypes_Active]</span>
                            }
                            else
                            {
                                <span class="status-badge" style="background:rgba(239,68,68,.1);color:#991b1b;">
                                    @_sharedResources[SharedResourcesKeys.CompanyTypes_Inactive]
                                </span>
                            }
                        </td>
                        <td>
                            <div class="actions-cell">
                                <a class="action-btn edit" title="@_sharedResources[SharedResourcesKeys.Edit]"
                                   asp-action="EditCompanyType" asp-route-id="@type.Id">
                                    <span class="material-symbols-outlined">edit</span>
                                </a>

                                <a class="action-btn toggle" title="@_sharedResources[SharedResourcesKeys.ToggleStatus]"
                                   asp-action="ToggleActiveCompanyType" asp-route-id="@type.Id">
                                    <span class="material-symbols-outlined">
                                        @(type.IsActive == true ? "toggle_on" : "toggle_off")
                                    </span>
                                </a>

                                <a class="action-btn delete" title="@_sharedResources[SharedResourcesKeys.Delete]"
                                   asp-action="DeleteCompanyType" asp-route-id="@type.Id"
                                   onclick="return confirm('@_sharedResources[SharedResourcesKeys.Delete_Confirm]');">
                                    <span class="material-symbols-outlined">delete</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/jquery-3.7.1.min.js"></script>
    <script src="~/lib/datatable/jquery.datatables.min.js"></script>
    <script>
        var isArabic = @(isArabic ? "true" : "false");
        var dt;

        $(document).ready(function () {
            dt = $('#companyTypesTable').DataTable({
                responsive: true,
                pageLength: 10,
                ordering: true,
                autoWidth: false,
                language: {
                    search:       isArabic ? "بحث:"   : "Search:",
                    lengthMenu:   isArabic ? "عرض _MENU_ عناصر لكل صفحة" : "Show _MENU_ entries",
                    zeroRecords:  isArabic ? "لا يوجد عناصر لعرضها"       : "No matching records",
                    info:         isArabic ? "عرض _START_ إلى _END_ من _TOTAL_ عنصر" : "Showing _START_ to _END_ of _TOTAL_ entries",
                    infoEmpty:    isArabic ? "لا يوجد عناصر متاحة"         : "No entries available",
                    infoFiltered: isArabic ? "(مصفى من _MAX_ عنصر)"        : "(filtered from _MAX_ total entries)",
                    paginate: {
                        first:    isArabic ? "الأول"  : "First",
                        last:     isArabic ? "الأخير" : "Last",
                        next:     isArabic ? "التالي" : "Next",
                        previous: isArabic ? "السابق" : "Previous"
                    }
                },
                columnDefs: [{ orderable: false, targets: [0, 3] }],
                drawCallback: function () {
                    var api = this.api();
                    var startIndex = api.page.info().start;
                    api.column(0, { page: 'current' }).nodes().each(function (cell, i) {
                        cell.innerHTML = startIndex + i + 1;
                    });
                }
            });

            $('#statusFilter').on('change', function () {
                dt.column(2).search($(this).val(), false, false).draw();
            });

            var _serverMsg = '@Html.Raw(TempData["Success"] ?? "")';
            var _serverErr = '@Html.Raw(TempData["Error"] ?? "")';
            if (_serverMsg) showToast(_serverMsg, 'success');
            if (_serverErr) showToast(_serverErr, 'error');
        });
    </script>
}