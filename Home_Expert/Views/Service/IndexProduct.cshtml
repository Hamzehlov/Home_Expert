@model IEnumerable<Home_Expert.Models.Product>
@using Home_Expert.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> _sharedResources

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isArabic = culture.StartsWith("ar");
    var tableDir = isArabic ? "rtl" : "ltr";
}

@section Styles {
    <link rel="stylesheet" href="~/css/table.css" />
    <link href="~/lib/datatable/datatable.min.css" rel="stylesheet" />
}

<div class="page-wrapper">

    <div class="page-header">
        <div class="page-header-text">
            <div class="breadcrumb">
                <a href="@Url.Action("Index", "Home")">@_sharedResources[SharedResourcesKeys.Dashboard]</a>
                <span class="material-symbols-outlined sep">@(isArabic ? "chevron_left" : "chevron_right")</span>
                <span>@_sharedResources[SharedResourcesKeys.Products_Title]</span>
            </div>
            <h1>@_sharedResources[SharedResourcesKeys.Products_Title]</h1>
            <p>@_sharedResources[SharedResourcesKeys.Products_Description]</p>
        </div>
    </div>

    <div class="stats-row">
        <div class="stat-pill">
            <div class="stat-pill-icon" style="background:rgba(10,61,68,.1);color:#0A3D44;">
                <span class="material-symbols-outlined">inventory_2</span>
            </div>
            <div>
                <div class="stat-pill-val">@Model.Count()</div>
                <div class="stat-pill-label">@_sharedResources[SharedResourcesKeys.Products_Total]</div>
            </div>
        </div>
        <div class="stat-pill">
            <div class="stat-pill-icon green">
                <span class="material-symbols-outlined">check_circle</span>
            </div>
            <div>
                <div class="stat-pill-val">@Model.Count(p => p.IsActive == true)</div>
                <div class="stat-pill-label">@_sharedResources[SharedResourcesKeys.Products_Active]</div>
            </div>
        </div>
        <div class="stat-pill">
            <div class="stat-pill-icon red">
                <span class="material-symbols-outlined">cancel</span>
            </div>
            <div>
                <div class="stat-pill-val">@Model.Count(p => p.IsActive == false)</div>
                <div class="stat-pill-label">@_sharedResources[SharedResourcesKeys.Products_Inactive]</div>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="table-toolbar-extra">
            <a class="btn btn-primary" asp-action="CreateProduc">
                <span class="material-symbols-outlined">add</span>
                @_sharedResources[SharedResourcesKeys.Products_AddNew]
            </a>
            <select class="tbl-filter" id="statusFilter">
                <option value="">@_sharedResources[SharedResourcesKeys.Filter_AllStatus]</option>
                <option value="active">@_sharedResources[SharedResourcesKeys.Products_Active]</option>
                <option value="inactive">@_sharedResources[SharedResourcesKeys.Products_Inactive]</option>
            </select>
        </div>

        <table id="productsTable" class="data-table" style="width:100%" dir="@tableDir">
            <thead>
                <tr>
                    <th>#</th>
                    <th>@_sharedResources[SharedResourcesKeys.Products_Name]</th>
                    <th>@_sharedResources[SharedResourcesKeys.Products_Description]</th>
                    <th>@_sharedResources[SharedResourcesKeys.Products_Image]</th>
                    <th>@_sharedResources[SharedResourcesKeys.Products_Company]</th>
                    <th>@_sharedResources[SharedResourcesKeys.Products_Status]</th>
                    <th>@_sharedResources[SharedResourcesKeys.Products_Actions]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    var statusKey = product.IsActive == true ? "active" : "inactive";
                    var name = isArabic ? product.NameAr : (product.NameEn ?? product.NameAr);
                    var nameOther = isArabic ? (product.NameEn ?? "-") : (product.NameAr ?? "-");
                    var desc = string.IsNullOrEmpty(product.Description) ? "-" : product.Description;

                    <tr data-status="@statusKey">
                        <td class="row-num" style="font-weight:700;color:var(--primary);"></td>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">
                                    @if (product.ProductImages.Any(pi => pi.IsMain))
                                    {
                                        var mainImg = product.ProductImages.First(pi => pi.IsMain).ImageData;
                                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(mainImg)" alt="Product Image" />
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined">image_not_supported</span>
                                    }
                                </div>
                                <div>
                                    <div class="company-name">@name</div>
                                    <div class="company-other-name" style="font-size:.75rem;color:var(--muted);">@nameOther</div>
                                </div>
                            </div>
                        </td>
                        <td>@desc</td>
                        <td>
                            @if (product.ProductImages != null && product.ProductImages.Any())
                            {
                                <button class="btn btn-sm btn-outline-primary" onclick="openImagesModal(@product.Id)">
                                    عرض الصور (@product.ProductImages.Count)
                                </button>
                            }
                            else
                            {
                                <span class="text-muted">لا توجد صور</span>
                            }
                        </td>
                        <td>@(isArabic? product.Vendor.CompanyNameAr : (product.Vendor.CompanyNameEn ?? product.Vendor.CompanyNameAr))</td>
                        <td data-search="@statusKey">
                            @if (product.IsActive == true)
                            {
                                <span class="status-badge active">@_sharedResources[SharedResourcesKeys.Products_Active]</span>
                            }
                            else
                            {
                                <span class="status-badge" style="background:rgba(239,68,68,.1);color:#991b1b;">
                                    @_sharedResources[SharedResourcesKeys.Products_Inactive]
                                </span>
                            }
                        </td>
                        <td>
                            <div class="actions-cell">
                                <a class="action-btn edit" title="@_sharedResources[SharedResourcesKeys.Edit]"
                                   asp-action="EditProduc" asp-route-id="@product.Id">
                                    <span class="material-symbols-outlined">edit</span>
                                </a>

                                <a class="action-btn toggle" title="@_sharedResources[SharedResourcesKeys.ToggleStatus]"
                                   asp-action="ToggleProductStatus" asp-route-id="@product.Id">
                                    <span class="material-symbols-outlined">
                                        @(product.IsActive == true ? "toggle_on" : "toggle_off")
                                    </span>
                                </a>

                                <a class="action-btn delete" title="@_sharedResources[SharedResourcesKeys.Delete]"
                                   asp-action="DeleteProduct" asp-route-id="@product.Id"
                                   onclick="return confirm('@_sharedResources[SharedResourcesKeys.Delete_Confirm]');">
                                    <span class="material-symbols-outlined">delete</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/jquery-3.7.1.min.js"></script>
    <script src="~/lib/datatable/jquery.datatables.min.js"></script>
    <script>
        var isArabic = @(isArabic ? "true" : "false");
        var dt;

        $(document).ready(function () {
            dt = $('#productsTable').DataTable({
                responsive: true,
                pageLength: 10,
                ordering: true,
                autoWidth: false,
                language: {
                    search:       isArabic ? "بحث:"   : "Search:",
                    lengthMenu:   isArabic ? "عرض _MENU_ عناصر لكل صفحة" : "Show _MENU_ entries",
                    zeroRecords:  isArabic ? "لا يوجد عناصر لعرضها"       : "No matching records",
                    info:         isArabic ? "عرض _START_ إلى _END_ من _TOTAL_ عنصر" : "Showing _START_ to _END_ of _TOTAL_ entries",
                    infoEmpty:    isArabic ? "لا يوجد عناصر متاحة"         : "No entries available",
                    infoFiltered: isArabic ? "(مصفى من _MAX_ عنصر)"        : "(filtered from _MAX_ total entries)",
                    paginate: {
                        first:    isArabic ? "الأول"  : "First",
                        last:     isArabic ? "الأخير" : "Last",
                        next:     isArabic ? "التالي" : "Next",
                        previous: isArabic ? "السابق" : "Previous"
                    }
                },
                columnDefs: [{ orderable: false, targets: [0, 6] }],
                drawCallback: function () {
                    var api = this.api();
                    var startIndex = api.page.info().start;
                    api.column(0, { page: 'current' }).nodes().each(function (cell, i) {
                        cell.innerHTML = startIndex + i + 1;
                    });
                }
            });

            $('#statusFilter').on('change', function () {
                dt.column(5).search($(this).val(), false, false).draw();
            });

            var _serverMsg = '@Html.Raw(TempData["Success"] ?? "")';
            var _serverErr = '@Html.Raw(TempData["Error"] ?? "")';
            if (_serverMsg) showToast(_serverMsg, 'success');
            if (_serverErr) showToast(_serverErr, 'error');
        });
    </script>
}