@model Home_Expert.ViewModel.Service.CodeViewModel

@using Home_Expert.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> _sharedResources
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isArabic = culture.StartsWith("ar");
}

@section Styles {
    <link rel="stylesheet" href="~/css/form.css" />
}

<div class="page-wrapper">

    <!-- Header -->
    <div class="page-header">
        <div class="page-header-text">
            <div class="breadcrumb">
                <a href="@Url.Action("Index", "Home")">@_sharedResources[SharedResourcesKeys.Dashboard]</a>
                <span class="material-symbols-outlined sep">@(isArabic ? "chevron_left" : "chevron_right")</span>
                <a href="@Url.Action("Index", "CompanyTypes")">@_sharedResources[SharedResourcesKeys.CompanyTypes_Title]</a>
                <span class="material-symbols-outlined sep">@(isArabic ? "chevron_left" : "chevron_right")</span>
                <span>@_sharedResources[SharedResourcesKeys.CompanyTypes_AddNew]</span>
            </div>
            <h1>@_sharedResources[SharedResourcesKeys.CompanyTypes_AddNew]</h1>
            <p>@_sharedResources[SharedResourcesKeys.CompanyTypes_Description]</p>
        </div>
        <a href="@Url.Action("Index", "CompanyTypes")" class="btn btn-outline">
            <span class="material-symbols-outlined">@(isArabic ? "arrow_forward" : "arrow_back")</span>
            @_sharedResources[SharedResourcesKeys.Back]
        </a>
    </div>

    <form asp-action="CreateCompanyType" method="post">
        @Html.AntiForgeryToken()

        <div class="form-layout">

            <!-- Main Form -->
            <div>

                <!-- Company Type Info -->
                <div class="form-card">
                    <div class="form-card-header">
                        <div class="header-icon">
                            <span class="material-symbols-outlined">business</span>
                        </div>
                        <h3>@_sharedResources[SharedResourcesKeys.CompanyTypes_Title]</h3>
                    </div>

                    <div class="form-card-body">

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">
                                    <span class="required">*</span>
                                    @_sharedResources[SharedResourcesKeys.CompanyTypes_Name] (AR)
                                </label>
                                <input asp-for="DescCodeAr" class="form-control" />
                                <span asp-validation-for="DescCodeAr" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label">
                                    <span class="required">*</span>
                                    @_sharedResources[SharedResourcesKeys.CompanyTypes_Name] (EN)
                                </label>
                                <input asp-for="DescCodeEn" class="form-control" />
                                <span asp-validation-for="DescCodeEn" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">
                                    @_sharedResources[SharedResourcesKeys.CompanyTypes_Status]
                                </label>
                                <select asp-for="IsActive" class="form-control">
                                    <option value="true">@_sharedResources[SharedResourcesKeys.CompanyTypes_Active]</option>
                                    <option value="false">@_sharedResources[SharedResourcesKeys.CompanyTypes_Inactive]</option>
                                </select>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <span class="material-symbols-outlined">save</span>
                        @_sharedResources[SharedResourcesKeys.Save]
                    </button>
                    <a href="@Url.Action("Index", "CompanyTypes")" class="btn btn-outline">
                        @_sharedResources[SharedResourcesKeys.Cancel]
                    </a>
                </div>

            </div>

            <!-- Sidebar -->
            <div>
                <div class="sidebar-card">
                    <div class="sidebar-card-header">
                        <h4>💡 @_sharedResources[SharedResourcesKeys.Input_Tips]</h4>
                    </div>
                    <div class="sidebar-card-body">
                        <ul class="tips-list">
                            <li>
                                <span class="material-symbols-outlined">check_circle</span>
                                @_sharedResources[SharedResourcesKeys.Tip_Required]
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="sidebar-card">
                    <div class="sidebar-card-header">
                        <h4>📊 @_sharedResources[SharedResourcesKeys.Quick_Stats]</h4>
                    </div>
                    <div class="sidebar-card-body">
                        <div class="sidebar-stat-row">
                            <span class="sidebar-stat-label">@_sharedResources[SharedResourcesKeys.CompanyTypes_Total]</span>
                            <span class="sidebar-stat-val">@ViewBag.Total</span>
                        </div>
                        <div class="sidebar-stat-row">
                            <span class="sidebar-stat-label">@_sharedResources[SharedResourcesKeys.CompanyTypes_Active]</span>
                            <span class="sidebar-stat-val">@ViewBag.Active</span>
                        </div>
                        <div class="sidebar-stat-row">
                            <span class="sidebar-stat-label">@_sharedResources[SharedResourcesKeys.CompanyTypes_Inactive]</span>
                            <span class="sidebar-stat-val" style="color:var(--accent);">@ViewBag.Inactive</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>